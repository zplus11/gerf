     RowBox[{"x", ",", "t"}], "]"}], "\[Rule]", 
    RowBox[{"c", "+", 
     RowBox[{"2", " ", "\[Nu]", " ", 
      RowBox[{"Tan", "[", 
       RowBox[{"x", "-", 
        FractionBox[
         RowBox[{"c", " ", 
          SuperscriptBox["t", "\[Alpha]"]}], "\[Alpha]"]}], "]"}]}]}]}], ",", 
