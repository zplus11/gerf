Cell[CellGroupData[{

Cell[BoxData[
 InterpretationBox[Cell[
  "\"BalanceConstant\"", "ExampleSubsection",ExpressionUUID->
   "f3761318-33e7-ca4e-a8f8-0b1a121b7300"],
  $Line = 0; Null]], "ExampleSubsection",
 CellChangeTimes->{{3.989115915898161*^9, 3.989115918371372*^9}, {
  3.989116030831623*^9, 3.9891160327863083`*^9}},
 CellID->160991384,ExpressionUUID->"b1481a06-94dc-0d4d-8941-7a3461d01f91"],

Cell["\<\
Ordinarily, the balance constant is calculated automatically:\
\>", "ExampleText",
 CellChangeTimes->{{3.9891160347878056`*^9, 3.989116045035307*^9}, 
   3.989116194900429*^9},
 CellID->20358894,ExpressionUUID->"aa2cf430-c306-9948-b32c-a3b5cbc6d254"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"GERFSolve", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      SubscriptBox["\[PartialD]", "t"], 
      RowBox[{"u", "[", 
       RowBox[{"x", ",", "t"}], "]"}]}], "+", 
     RowBox[{
      RowBox[{"u", "[", 
       RowBox[{"x", ",", "t"}], "]"}], 
      RowBox[{
       SubscriptBox["\[PartialD]", "x"], 
       RowBox[{"u", "[", 
        RowBox[{"x", ",", "t"}], "]"}]}]}], "-", 
     RowBox[{"\[Nu]", " ", 
      RowBox[{
       SubscriptBox["\[PartialD]", 
        RowBox[{"x", ",", "x"}]], 
       RowBox[{"u", "[", 
        RowBox[{"x", ",", "t"}], "]"}]}]}]}], "==", "0"}], ",", 
   RowBox[{"u", "[", 
    RowBox[{"x", ",", "t"}], "]"}], ",", 
   RowBox[{"\"\<BalanceConstant\>\"", "->", "Automatic"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.9891160566127644`*^9, 3.9891160657670536`*^9}},
 CellLabel->"In[1]:=",
 CellID->20034340,ExpressionUUID->"38e3d88c-bbd0-1748-b88b-2673149584d2"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"u", "[", 
     RowBox[{"x", ",", "t"}], "]"}], "\[Rule]", 
    RowBox[{
     SubscriptBox["\[ScriptCapitalA]", "0"], "+", 
     FractionBox[
      RowBox[{"2", " ", "\[Nu]", " ", 
       SubscriptBox["\[ScriptW]", "x"]}], 
      RowBox[{"1", "+", 
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{
         RowBox[{"x", " ", 
          SubscriptBox["\[ScriptW]", "x"]}], "+", 
         RowBox[{"t", " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{
             RowBox[{"-", 
              SubscriptBox["\[ScriptCapitalA]", "0"]}], " ", 
             SubscriptBox["\[ScriptW]", "x"]}], "-", 
            RowBox[{"\[Nu]", " ", 
             SubsuperscriptBox["\[ScriptW]", "x", "2"]}]}], ")"}]}]}]]}]]}]}],
    "}"}], "}"}]], "Output",
 CellChangeTimes->{{3.9891160498479805`*^9, 3.989116066190359*^9}, 
   3.990357332940487*^9, 3.990517263548588*^9},
 CellLabel->"Out[1]=",
 CellID->4122039,ExpressionUUID->"77d69a60-1135-bf40-b184-1488f6157ec1"]
}, Open  ]],

