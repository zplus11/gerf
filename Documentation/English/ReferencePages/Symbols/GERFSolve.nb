Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"GERFSolve", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      SubscriptBox["\[PartialD]", "t"], 
      RowBox[{"u", "[", 
       RowBox[{"x", ",", "t"}], "]"}]}], "+", 
     RowBox[{
      RowBox[{"u", "[", 
       RowBox[{"x", ",", "t"}], "]"}], 
      RowBox[{
       SubscriptBox["\[PartialD]", "x"], 
       RowBox[{"u", "[", 
        RowBox[{"x", ",", "t"}], "]"}]}]}], "-", 
     RowBox[{"\[Nu]", " ", 
      RowBox[{
       SubscriptBox["\[PartialD]", 
        RowBox[{"x", ",", "x"}]], 
       RowBox[{"u", "[", 
        RowBox[{"x", ",", "t"}], "]"}]}]}]}], "==", "0"}], ",", 
   RowBox[{"u", "[", 
    RowBox[{"x", ",", "t"}], "]"}], ",", 
   RowBox[{"\"\<BalanceConstant\>\"", "->", "2"}]}], "]"}]], "Input",
 CellChangeTimes->{3.989116077902155*^9},
 CellLabel->"In[2]:=",
 CellID->548171228,ExpressionUUID->"fa092ff2-54e2-8d49-a75d-eb3304928ebf"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"u", "[", 
     RowBox[{"x", ",", "t"}], "]"}], "\[Rule]", 
    RowBox[{
     RowBox[{"4", " ", 
      SubscriptBox["\[ScriptCapitalA]", 
       RowBox[{"-", "2"}]]}], "+", 
     RowBox[{"2", " ", 
      SubscriptBox["\[ScriptCapitalA]", 
       RowBox[{"-", "1"}]]}], "+", 
     SubscriptBox["\[ScriptCapitalA]", "0"], "+", 
     RowBox[{
      FractionBox["1", "4"], " ", 
      RowBox[{"(", 
       RowBox[{
        SubscriptBox["\[ScriptCapitalA]", 
         RowBox[{"-", "2"}]], "+", 
        FractionBox[
         SubscriptBox["\[ScriptCapitalA]", 
          RowBox[{"-", "1"}]], "2"], "-", 
        FractionBox[
         SubscriptBox["\[ScriptCapitalA]", "1"], "2"]}], ")"}]}], "+", 
     FractionBox[
      SubscriptBox["\[ScriptCapitalA]", "1"], "2"]}]}], ",", 
   RowBox[{
    RowBox[{"u", "[", 
     RowBox[{"x", ",", "t"}], "]"}], "\[Rule]", 
    RowBox[{
     RowBox[{"2", " ", 
      SubscriptBox["\[ScriptCapitalA]", 
       RowBox[{"-", "1"}]]}], "+", 
     SubscriptBox["\[ScriptCapitalA]", "0"], "+", 
     RowBox[{
      FractionBox["1", "4"], " ", 
      RowBox[{"(", 
       RowBox[{
        FractionBox[
         SubscriptBox["\[ScriptCapitalA]", 
          RowBox[{"-", "1"}]], "2"], "-", 
        FractionBox[
         SubscriptBox["\[ScriptCapitalA]", "1"], "2"]}], ")"}]}], "+", 
     FractionBox[
      SubscriptBox["\[ScriptCapitalA]", "1"], "2"]}]}], ",", 
   RowBox[{
    RowBox[{"u", "[", 
     RowBox[{"x", ",", "t"}], "]"}], "\[Rule]", 
    RowBox[{
     SubscriptBox["\[ScriptCapitalA]", "0"], "+", 
     FractionBox[
      SubscriptBox["\[ScriptCapitalA]", "1"], 
      RowBox[{"1", "+", 
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{
         RowBox[{"x", " ", 
          SubscriptBox["\[ScriptW]", "x"]}], "+", 
         RowBox[{
          FractionBox["1", "2"], " ", "t", " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{
             RowBox[{"-", "2"}], " ", 
             SubscriptBox["\[ScriptCapitalA]", "0"], " ", 
             SubscriptBox["\[ScriptW]", "x"]}], "-", 
            RowBox[{
             SubscriptBox["\[ScriptCapitalA]", "1"], " ", 
             SubscriptBox["\[ScriptW]", "x"]}]}], ")"}]}]}]]}]]}]}], ",", 
   RowBox[{
    RowBox[{"u", "[", 
     RowBox[{"x", ",", "t"}], "]"}], "\[Rule]", 
    SubscriptBox["\[ScriptCapitalA]", "0"]}]}], "}"}]], "Output",
