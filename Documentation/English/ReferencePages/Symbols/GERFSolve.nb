       SubscriptBox["\[PartialD]", 
        RowBox[{"x", ",", "x"}]], 
       RowBox[{"u", "[", 
        RowBox[{"x", ",", "t"}], "]"}]}]}]}], "==", "0"}]}], ";", 
  RowBox[{
   RowBox[{"GERFSolve", "[", 
    RowBox[{"burgers", ",", 
     RowBox[{"u", "[", 
      RowBox[{"x", ",", "t"}], "]"}], ",", 
     RowBox[{"\"\<WaveConstants\>\"", "->", 
