Notebook[{

Cell[CellGroupData[{
Cell["GERFSolve", "ObjectName",
 CellID->322747057,ExpressionUUID->"5b2a6b6b-3ab9-8642-804d-c44d0def25e9"],

Cell[TextData[{
 Cell["   ", "ModInfo",ExpressionUUID->"5e8eaa3b-c1df-2e4b-af53-00b6032f754c"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["GERFSolve",
    BaseStyle->"Link",
    ButtonData->"paclet:Taggar/GERF/ref/GERFSolve"], "[", 
   RowBox[{
    RowBox[{
     StyleBox["lhs", "TI"], "=", 
     StyleBox["rhs", "TI"]}], ",", 
    RowBox[{
     StyleBox["u", "TI"], "[", 
     StyleBox["vars", "TI"], "]"}], ",", "..."}], "]"}]], "InlineFormula",
  ExpressionUUID->"f9cd0f3a-1098-2043-b55d-4431217b60c1"],
 " \[LineSeparator]solves the NLPDE given by ",
 Cell[BoxData[
  RowBox[{
   StyleBox["lhs", "TI"], "=", 
   StyleBox["rhs", "TI"]}]], "InlineFormula",ExpressionUUID->
  "f37546a9-7bbb-5643-a043-97ea9ec637ce"],
 " for ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"u", "[", "vars", "]"}], "TI"]], "InlineFormula",ExpressionUUID->
  "a6911a84-240d-df49-a4b3-d52b1d8439ae"],
 " using the GERF method."
}], "Usage",
 CellChangeTimes->{{3.9839372797049026`*^9, 3.9839373520046005`*^9}},
 CellID->10018101,ExpressionUUID->"d224f699-e5dc-ff4b-9754-af3695dda552"],

Cell["The following options can be given: ", "Notes",
 CellID->13178,ExpressionUUID->"573e0b28-0eee-e047-9783-41f5ac4d5250"],

Cell[BoxData[GridBox[{
   {Cell["      ", "ModInfo",ExpressionUUID->
     "238c5297-10ee-6c40-9a0b-72e46977a63d"], "\"\<BalanceConstant\>\"", 
    "Automatic", Cell["\<\
balance constant of the equation obtained using balancing principle\
\>", "TableText",
     CellChangeTimes->{3.327659391375*^9},ExpressionUUID->
     "24cc9d90-0f6f-4a4f-a325-b3651770e166"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "92638fd5-aec1-c141-9f22-5978d1d6d2df"], "\"\<RationalFunction\>\"", 
    RowBox[{
     FractionBox["1", 
      RowBox[{"1", "+", 
       SuperscriptBox["\[ExponentialE]", "#"]}]], "&"}], Cell[
    "the general exponential rational function used for solving", "TableText",
     CellChangeTimes:>{3.32765943476563*^9, 3.32787906595725*^9, 
      3.34660524546012*^9},ExpressionUUID->
     "7ae71ba4-db4a-6c46-b950-443523fe2148"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "bdd6f656-6dd8-9e40-9065-83aebe7a052d"], "\"\<WaveConstants\>\"", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox[
       StyleBox["\[ScriptW]", "TI"], 
       StyleBox["x", "TI"]], ",", 
      SubscriptBox[
       StyleBox["\[ScriptW]", "TI"], 
       StyleBox["y", "TI"]], ",", "...", ",", 
      SubscriptBox[
       StyleBox["\[ScriptW]", "TI"], 
       StyleBox["t", "TI"]]}], "}"}], Cell[
    "the wave constants used in wave transformation", "TableText",
     CellChangeTimes:>{3.32765943476563*^9, 3.32787906595725*^9, 
      3.34660524546012*^9},ExpressionUUID->
     "4b9b936e-76ab-514b-81ad-e64da5499d24"]}
  }]], "3ColumnTableMod",
 CellChangeTimes->{
  3.32765943476563*^9, 3.32766053485938*^9, 3.32787901726975*^9, 
   3.32787909470725*^9, 3.34660524546012*^9, {3.3751958270231285`*^9, 
   3.3751958270543785`*^9}, 3.3839149012241626`*^9, {3.9839374679351177`*^9, 
   3.9839377769462547`*^9}, {3.98393783031629*^9, 3.983937853169945*^9}, {
   3.9839380224752026`*^9, 3.983938043485796*^9}, {3.983939043040079*^9, 
   3.983939091958441*^9}, {3.9839393456820583`*^9, 3.9839393627207184`*^9}, {
   3.989114240264559*^9, 3.989114241551552*^9}, {3.989114302461073*^9, 
   3.989114532312729*^9}},
 CellID->694357680,ExpressionUUID->"e25d47f1-67fc-4f46-b541-5c03bbe4d207"],

Cell["\"OutputMode\" takes the following values:", "Notes",
 CellChangeTimes->{{3.9839380579785576`*^9, 3.9839380665058746`*^9}},
 CellID->12765947,ExpressionUUID->"c7069855-7d7e-af4c-84e3-776105157d59"],

Cell[BoxData[GridBox[{
