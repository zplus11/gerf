  "\"RationalFunction\"", "ExampleSubsection",ExpressionUUID->
   "cb51a73c-b8dc-6344-9180-3ecb8834d5f2"],
  $Line = 0; Null]], "ExampleSubsection",
 CellChangeTimes->{{3.989115789877846*^9, 3.9891157926262035`*^9}},
 CellID->149214518,ExpressionUUID->"168a5712-d605-8a43-9ab8-705714dd32b5"],

Cell[BoxData[
 RowBox[{
  RowBox[{"burgers", "=", 
   RowBox[{
    RowBox[{
     RowBox[{
      SubscriptBox["\[PartialD]", "t"], 
      RowBox[{"u", "[", 
       RowBox[{"x", ",", "t"}], "]"}]}], "+", 
     RowBox[{
      RowBox[{"u", "[", 
       RowBox[{"x", ",", "t"}], "]"}], 
      RowBox[{
       SubscriptBox["\[PartialD]", "x"], 
       RowBox[{"u", "[", 
        RowBox[{"x", ",", "t"}], "]"}]}]}], "-", 
     RowBox[{"\[Nu]", " ", 
      RowBox[{
       SubscriptBox["\[PartialD]", 
        RowBox[{"x", ",", "x"}]], 
       RowBox[{"u", "[", 
        RowBox[{"x", ",", "t"}], "]"}]}]}]}], "==", "0"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9891157945700207`*^9, 3.98911580340452*^9}},
 CellLabel->"In[1]:=",
 CellID->5385389,ExpressionUUID->"5f502a34-e64d-e940-8511-cd68ed29fb83"],

Cell["Solving it with default value returns:", "ExampleText",
 CellChangeTimes->{{3.9891158074007015`*^9, 3.9891158142840137`*^9}, 
   3.989115850924679*^9},
 CellID->90352388,ExpressionUUID->"90044aa7-560e-7d4a-ac72-bcbc223737d8"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"GERFSolve", "[", 
  RowBox[{"burgers", ",", 
   RowBox[{"u", "[", 
    RowBox[{"x", ",", "t"}], "]"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.989115815801935*^9, 3.9891158197382584`*^9}},
 CellLabel->"In[2]:=",
 CellID->762382597,ExpressionUUID->"074384ad-b91d-d14a-8575-be825283933a"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"u", "[", 
     RowBox[{"x", ",", "t"}], "]"}], "\[Rule]", 
    RowBox[{
     SubscriptBox["\[ScriptCapitalA]", "0"], "+", 
     FractionBox[
      SubscriptBox["\[ScriptCapitalA]", "1"], 
      RowBox[{"1", "+", 
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{
         RowBox[{"x", " ", 
          SubscriptBox["\[ScriptW]", "x"]}], "+", 
         RowBox[{
          FractionBox["1", "2"], " ", "t", " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{
             RowBox[{"-", "2"}], " ", 
             SubscriptBox["\[ScriptCapitalA]", "0"], " ", 
             SubscriptBox["\[ScriptW]", "x"]}], "-", 
            RowBox[{
             SubscriptBox["\[ScriptCapitalA]", "1"], " ", 
             SubscriptBox["\[ScriptW]", "x"]}]}], ")"}]}]}]]}]]}]}], ",", 
   RowBox[{
    RowBox[{"u", "[", 
     RowBox[{"x", ",", "t"}], "]"}], "\[Rule]", 
    SubscriptBox["\[ScriptCapitalA]", "0"]}], ",", 
   RowBox[{
    RowBox[{"u", "[", 
     RowBox[{"x", ",", "t"}], "]"}], "\[Rule]", 
    RowBox[{
     FractionBox[
      RowBox[{"5", " ", 
       SubscriptBox["\[ScriptCapitalA]", 
        RowBox[{"-", "1"}]]}], "2"], "+", 
     SubscriptBox["\[ScriptCapitalA]", "0"]}]}]}], "}"}]], "Output",
 CellChangeTimes->{3.9891158203047657`*^9, 3.9903515058449*^9, 
  3.9903572986814804`*^9},
 CellLabel->"Out[2]=",
 CellID->91079104,ExpressionUUID->"4033906f-00f0-d841-ab4c-643a724ecdd5"]
}, Open  ]],

Cell["Whereas a different rational function gives:", "ExampleText",
 CellChangeTimes->{{3.9891158216344604`*^9, 3.989115854140297*^9}},
 CellID->400879093,ExpressionUUID->"5e8aeae0-e935-3240-92fb-03fcbf771b6a"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"GERFSolve", "[", 
  RowBox[{"burgers", ",", 
   RowBox[{"u", "[", 
    RowBox[{"x", ",", "t"}], "]"}], ",", 
   RowBox[{"\"\<RationalFunction\>\"", "->", "Tan"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.989115835965212*^9, 3.9891158429446087`*^9}},
 CellLabel->"In[3]:=",
 CellID->589851442,ExpressionUUID->"14336c5d-7029-e64b-9d61-6b56dde57956"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"u", "[", 
     RowBox[{"x", ",", "t"}], "]"}], "\[Rule]", 
    RowBox[{
     SubscriptBox["\[ScriptCapitalA]", "0"], "+", 
     RowBox[{"2", " ", "\[Nu]", " ", 
      SubscriptBox["\[ScriptW]", "x"], " ", 
      RowBox[{"Tan", "[", 
       RowBox[{
        RowBox[{"x", " ", 
         SubscriptBox["\[ScriptW]", "x"]}], "-", 
        RowBox[{"t", " ", 
         SubscriptBox["\[ScriptCapitalA]", "0"], " ", 
         SubscriptBox["\[ScriptW]", "x"]}]}], "]"}]}]}]}], ",", 
   RowBox[{
    RowBox[{"u", "[", 
     RowBox[{"x", ",", "t"}], "]"}], "\[Rule]", 
    RowBox[{
     SubscriptBox["\[ScriptCapitalA]", "0"], "-", 
     RowBox[{"2", " ", "\[Nu]", " ", 
      RowBox[{"Cot", "[", 
       RowBox[{
        RowBox[{"x", " ", 
         SubscriptBox["\[ScriptW]", "x"]}], "-", 
        RowBox[{"t", " ", 
         SubscriptBox["\[ScriptCapitalA]", "0"], " ", 
         SubscriptBox["\[ScriptW]", "x"]}]}], "]"}], " ", 
      SubscriptBox["\[ScriptW]", "x"]}]}]}], ",", 
   RowBox[{
    RowBox[{"u", "[", 
     RowBox[{"x", ",", "t"}], "]"}], "\[Rule]", 
    RowBox[{
     SubscriptBox["\[ScriptCapitalA]", "0"], "-", 
     RowBox[{"2", " ", "\[Nu]", " ", 
      RowBox[{"Cot", "[", 
       RowBox[{
        RowBox[{"x", " ", 
         SubscriptBox["\[ScriptW]", "x"]}], "-", 
        RowBox[{"t", " ", 
         SubscriptBox["\[ScriptCapitalA]", "0"], " ", 
         SubscriptBox["\[ScriptW]", "x"]}]}], "]"}], " ", 
      SubscriptBox["\[ScriptW]", "x"]}], "+", 
     RowBox[{"2", " ", "\[Nu]", " ", 
      SubscriptBox["\[ScriptW]", "x"], " ", 
      RowBox[{"Tan", "[", 
       RowBox[{
        RowBox[{"x", " ", 
         SubscriptBox["\[ScriptW]", "x"]}], "-", 
        RowBox[{"t", " ", 
         SubscriptBox["\[ScriptCapitalA]", "0"], " ", 
         SubscriptBox["\[ScriptW]", "x"]}]}], "]"}]}]}]}]}], "}"}]], "Output",
 CellChangeTimes->{3.989115843594784*^9, 3.9903515115337753`*^9, 
  3.990357301190027*^9},
 CellLabel->"Out[3]=",
 CellID->53636811,ExpressionUUID->"1e742101-0b87-b04d-b831-97195236fd16"]
}, Open  ]],

Cell["A more complicated case:", "ExampleText",
 CellChangeTimes->{{3.9891158455048294`*^9, 3.9891158493009377`*^9}},
 CellID->11544469,ExpressionUUID->"ceb071f8-a980-c945-abf8-a605b8748608"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"GERFSolve", "[", 
  RowBox[{"burgers", ",", 
   RowBox[{"u", "[", 
    RowBox[{"x", ",", "t"}], "]"}], ",", 
   RowBox[{"\"\<RationalFunction\>\"", "->", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"1", "+", 
       RowBox[{"\[ImaginaryI]", " ", 
        RowBox[{"Tan", "[", "#", "]"}]}]}], "&"}], ")"}]}]}], "]"}]], "Input",
 CellChangeTimes->{{3.989115861264021*^9, 3.9891159073333397`*^9}},
 CellLabel->"In[4]:=",
 CellID->8201983,ExpressionUUID->"3a87b728-3bac-a142-8711-b2c8a2d4c560"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"u", "[", 
     RowBox[{"x", ",", "t"}], "]"}], "\[Rule]", 
    RowBox[{
     SubscriptBox["\[ScriptCapitalA]", "0"], "+", 
     RowBox[{
      SubscriptBox["\[ScriptCapitalA]", "1"], " ", 
      RowBox[{"(", 
       RowBox[{"1", "+", 
        RowBox[{"\[ImaginaryI]", " ", 
         RowBox[{"Tan", "[", 
          RowBox[{
           RowBox[{"x", " ", 
            SubscriptBox["\[ScriptW]", "x"]}], "+", 
           RowBox[{"t", " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{
               RowBox[{"-", 
                SubscriptBox["\[ScriptCapitalA]", "0"]}], " ", 
               SubscriptBox["\[ScriptW]", "x"]}], "-", 
              RowBox[{
               SubscriptBox["\[ScriptCapitalA]", "1"], " ", 
               SubscriptBox["\[ScriptW]", "x"]}]}], ")"}]}]}], "]"}]}]}], 
       ")"}]}]}]}], ",", 
   RowBox[{
    RowBox[{"u", "[", 
     RowBox[{"x", ",", "t"}], "]"}], "\[Rule]", 
    SubscriptBox["\[ScriptCapitalA]", "0"]}], ",", 
   RowBox[{
    RowBox[{"u", "[", 
     RowBox[{"x", ",", "t"}], "]"}], "\[Rule]", 
    RowBox[{
     FractionBox[
      RowBox[{"5", " ", 
       SubscriptBox["\[ScriptCapitalA]", 
        RowBox[{"-", "1"}]]}], "4"], "+", 
     SubscriptBox["\[ScriptCapitalA]", "0"]}]}]}], "}"}]], "Output",
 CellChangeTimes->{{3.989115870442684*^9, 3.989115907994709*^9}, 
   3.9903573215519466`*^9},
 CellLabel->"Out[4]=",
 CellID->261748178,ExpressionUUID->"9d221c2b-9ca0-1b46-934b-ee9bec5e607a"]
}, Open  ]],

