Cell[TextData[{
 "This is the Burgers' equation in ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{"1", "+", "1"}], ")"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "ca378713-cb69-9d49-be4c-8fde27a7506f"],
 "-dimensions:"
}], "ExampleText",
 CellChangeTimes->{3.9839382859513264`*^9},
 CellID->419655395,ExpressionUUID->"7359477c-b5fb-dd41-a4a3-fc83c5f06b4d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"burgers", "=", 
  RowBox[{
   RowBox[{
    RowBox[{
     SubscriptBox["\[PartialD]", "t"], 
     RowBox[{"u", "[", 
      RowBox[{"x", ",", "t"}], "]"}]}], "+", 
    RowBox[{
     RowBox[{"u", "[", 
      RowBox[{"x", ",", "t"}], "]"}], 
     RowBox[{
      SubscriptBox["\[PartialD]", "x"], 
      RowBox[{"u", "[", 
       RowBox[{"x", ",", "t"}], "]"}]}]}], "-", 
    RowBox[{"\[Nu]", " ", 
     RowBox[{
      SubscriptBox["\[PartialD]", 
       RowBox[{"x", ",", "x"}]], 
      RowBox[{"u", "[", 
       RowBox[{"x", ",", "t"}], "]"}]}]}]}], "==", "0"}]}]], "Input",
 CellChangeTimes->{{3.983938293903446*^9, 3.9839382947344036`*^9}},
 CellLabel->"In[1]:=",
 CellID->34374031,ExpressionUUID->"170f0887-2c0c-a345-9ebd-b7547478b66e"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    SuperscriptBox["u", 
     TagBox[
      RowBox[{"(", 
       RowBox[{"0", ",", "1"}], ")"}],
      Derivative],
     MultilineFunction->None], "[", 
    RowBox[{"x", ",", "t"}], "]"}], "+", 
   RowBox[{
    RowBox[{"u", "[", 
     RowBox[{"x", ",", "t"}], "]"}], " ", 
    RowBox[{
     SuperscriptBox["u", 
      TagBox[
       RowBox[{"(", 
        RowBox[{"1", ",", "0"}], ")"}],
       Derivative],
      MultilineFunction->None], "[", 
     RowBox[{"x", ",", "t"}], "]"}]}], "-", 
   RowBox[{"\[Nu]", " ", 
    RowBox[{
     SuperscriptBox["u", 
      TagBox[
       RowBox[{"(", 
        RowBox[{"2", ",", "0"}], ")"}],
       Derivative],
      MultilineFunction->None], "[", 
     RowBox[{"x", ",", "t"}], "]"}]}]}], "\[Equal]", "0"}]], "Output",
 CellChangeTimes->{3.983938295409622*^9, 3.983938385055683*^9, 
  3.983938615846382*^9, 3.9839387581855717`*^9, 3.983945824434929*^9, 
  3.983945897374161*^9, 3.983945978982292*^9, 3.983946182415764*^9, 
  3.983946231880129*^9, 3.9839462992335835`*^9, 3.983946360668928*^9, 
  3.9839470431737976`*^9, 3.983951299870962*^9, 3.9891145941304092`*^9, 
  3.9903512866197243`*^9, 3.9903572049966793`*^9},
 CellLabel->"Out[1]=",
 CellID->427757083,ExpressionUUID->"a0ac22d8-2767-1a49-b75d-15b5a66a1be7"]
}, Open  ]],

Cell["Solve it using GERF method:", "ExampleText",
 CellChangeTimes->{{3.983938299066225*^9, 3.983938304768261*^9}},
 CellID->64291742,ExpressionUUID->"13082efd-9bd1-914a-9707-9a8d64aab254"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"GERFSolve", "[", 
  RowBox[{"burgers", ",", 
   RowBox[{"u", "[", 
    RowBox[{"x", ",", "t"}], "]"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.983938782505268*^9, 3.9839387859446335`*^9}},
 CellLabel->"In[2]:=",
 CellID->7709824,ExpressionUUID->"68b790cc-43f8-ff41-a3a0-6cfb2e136fd2"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"u", "[", 
     RowBox[{"x", ",", "t"}], "]"}], "\[Rule]", 
    RowBox[{
     SubscriptBox["\[ScriptCapitalA]", "0"], "+", 
     FractionBox[
      SubscriptBox["\[ScriptCapitalA]", "1"], 
      RowBox[{"1", "+", 
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{
         RowBox[{"x", " ", 
          SubscriptBox["\[ScriptW]", "x"]}], "+", 
         RowBox[{
          FractionBox["1", "2"], " ", "t", " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{
             RowBox[{"-", "2"}], " ", 
             SubscriptBox["\[ScriptCapitalA]", "0"], " ", 
             SubscriptBox["\[ScriptW]", "x"]}], "-", 
            RowBox[{
             SubscriptBox["\[ScriptCapitalA]", "1"], " ", 
             SubscriptBox["\[ScriptW]", "x"]}]}], ")"}]}]}]]}]]}]}], ",", 
   RowBox[{
    RowBox[{"u", "[", 
     RowBox[{"x", ",", "t"}], "]"}], "\[Rule]", 
    SubscriptBox["\[ScriptCapitalA]", "0"]}], ",", 
   RowBox[{
    RowBox[{"u", "[", 
     RowBox[{"x", ",", "t"}], "]"}], "\[Rule]", 
    RowBox[{
     FractionBox[
      RowBox[{"5", " ", 
       SubscriptBox["\[ScriptCapitalA]", 
        RowBox[{"-", "1"}]]}], "2"], "+", 
     SubscriptBox["\[ScriptCapitalA]", "0"]}]}]}], "}"}]], "Output",
 CellChangeTimes->{
  3.983938786500757*^9, {3.9839458264237385`*^9, 3.983945869488962*^9}, 
   3.9839459010121784`*^9, 3.983945980529711*^9, {3.9839461567219696`*^9, 
   3.9839461849641495`*^9}, 3.9839462343916855`*^9, 3.983946301348608*^9, {
   3.9839463647962894`*^9, 3.9839463810711136`*^9}, 3.983951301106119*^9, 
   3.989114596941866*^9, 3.9903512878735695`*^9, 3.9903572067882156`*^9},
 CellLabel->"Out[2]=",
 CellID->42919055,ExpressionUUID->"29674fea-a54e-4a47-b9af-00e7471e1306"]
}, Open  ]],

Cell["Plot the solution:", "ExampleText",
