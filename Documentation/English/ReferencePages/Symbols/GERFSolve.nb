Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"u", "[", 
      RowBox[{"x", ",", "t"}], "]"}], "\[Rule]", 
     RowBox[{
      SubscriptBox["\[ScriptCapitalA]", "0"], "+", 
      RowBox[{"2", " ", "\[Nu]", " ", 
       SubscriptBox["\[ScriptW]", "x"], " ", 
       RowBox[{"Tan", "[", 
        RowBox[{
         RowBox[{"x", " ", 
          SubscriptBox["\[ScriptW]", "x"]}], "-", 
         RowBox[{"t", " ", 
          SubscriptBox["\[ScriptCapitalA]", "0"], " ", 
          SubscriptBox["\[ScriptW]", "x"]}]}], "]"}]}]}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"u", "[", 
      RowBox[{"x", ",", "t"}], "]"}], "\[Rule]", 
     RowBox[{
      SubscriptBox["\[ScriptCapitalA]", "0"], "-", 
      RowBox[{"2", " ", "\[Nu]", " ", 
       RowBox[{"Cot", "[", 
        RowBox[{
         RowBox[{"x", " ", 
          SubscriptBox["\[ScriptW]", "x"]}], "-", 
         RowBox[{"t", " ", 
          SubscriptBox["\[ScriptCapitalA]", "0"], " ", 
          SubscriptBox["\[ScriptW]", "x"]}]}], "]"}], " ", 
       SubscriptBox["\[ScriptW]", "x"]}]}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"u", "[", 
      RowBox[{"x", ",", "t"}], "]"}], "\[Rule]", 
     RowBox[{
      SubscriptBox["\[ScriptCapitalA]", "0"], "-", 
      RowBox[{"2", " ", "\[Nu]", " ", 
       RowBox[{"Cot", "[", 
        RowBox[{
         RowBox[{"x", " ", 
          SubscriptBox["\[ScriptW]", "x"]}], "-", 
         RowBox[{"t", " ", 
          SubscriptBox["\[ScriptCapitalA]", "0"], " ", 
          SubscriptBox["\[ScriptW]", "x"]}]}], "]"}], " ", 
       SubscriptBox["\[ScriptW]", "x"]}], "+", 
      RowBox[{"2", " ", "\[Nu]", " ", 
       SubscriptBox["\[ScriptW]", "x"], " ", 
       RowBox[{"Tan", "[", 
        RowBox[{
         RowBox[{"x", " ", 
          SubscriptBox["\[ScriptW]", "x"]}], "-", 
         RowBox[{"t", " ", 
          SubscriptBox["\[ScriptCapitalA]", "0"], " ", 
          SubscriptBox["\[ScriptW]", "x"]}]}], "]"}]}]}]}], "}"}]}], 
  "}"}]], "Output",
 CellChangeTimes->{3.989115843594784*^9, 3.9903515115337753`*^9, 
  3.990357301190027*^9, 3.9905172486938744`*^9},
