}, Open  ]],

Cell[TextData[{
 "The package converts ",
 Cell[BoxData[
  ButtonBox["Tan",
   BaseStyle->"Link"]], "InlineFormula",ExpressionUUID->
  "d609b1e8-b842-df46-9525-482950a505ec"],
 " to its exponential form:"
}], "ExampleText",
 CellChangeTimes->{{3.9891146996646175`*^9, 3.9891147178982964`*^9}},
 CellID->33223626,ExpressionUUID->"a70f6f6e-f737-9b41-a4f3-8a95e2025794"],

