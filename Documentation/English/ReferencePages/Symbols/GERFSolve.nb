Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"u", "[", 
     RowBox[{"x", ",", "t"}], "]"}], "\[Rule]", 
    RowBox[{
     SubscriptBox["\[ScriptCapitalA]", "0"], "-", 
     RowBox[{"2", " ", "\[ImaginaryI]", " ", "\[Nu]", " ", 
      SubscriptBox["\[ScriptW]", "x"], " ", 
      RowBox[{"(", 
       RowBox[{"1", "+", 
        RowBox[{"\[ImaginaryI]", " ", 
         RowBox[{"Tan", "[", 
          RowBox[{
           RowBox[{"x", " ", 
            SubscriptBox["\[ScriptW]", "x"]}], "-", 
           RowBox[{"t", " ", 
            SubscriptBox["\[ScriptW]", "x"], " ", 
            RowBox[{"(", 
             RowBox[{
              SubscriptBox["\[ScriptCapitalA]", "0"], "-", 
              RowBox[{"2", " ", "\[ImaginaryI]", " ", "\[Nu]", " ", 
               SubscriptBox["\[ScriptW]", "x"]}]}], ")"}]}]}], "]"}]}]}], 
       ")"}]}]}]}], "}"}], "}"}]], "Output",
 CellChangeTimes->{{3.989115870442684*^9, 3.989115907994709*^9}, 
