 CellLabel->"In[1]:=",
 CellID->20034340,ExpressionUUID->"38e3d88c-bbd0-1748-b88b-2673149584d2"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"u", "[", 
     RowBox[{"x", ",", "t"}], "]"}], "\[Rule]", 
    RowBox[{
     SubscriptBox["\[ScriptCapitalA]", "0"], "+", 
     FractionBox[
      SubscriptBox["\[ScriptCapitalA]", "1"], 
      RowBox[{"1", "+", 
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{
         RowBox[{"x", " ", 
          SubscriptBox["\[ScriptW]", "x"]}], "+", 
         RowBox[{
          FractionBox["1", "2"], " ", "t", " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{
             RowBox[{"-", "2"}], " ", 
             SubscriptBox["\[ScriptCapitalA]", "0"], " ", 
             SubscriptBox["\[ScriptW]", "x"]}], "-", 
            RowBox[{
             SubscriptBox["\[ScriptCapitalA]", "1"], " ", 
             SubscriptBox["\[ScriptW]", "x"]}]}], ")"}]}]}]]}]]}]}], ",", 
   RowBox[{
    RowBox[{"u", "[", 
     RowBox[{"x", ",", "t"}], "]"}], "\[Rule]", 
    SubscriptBox["\[ScriptCapitalA]", "0"]}], ",", 
   RowBox[{
    RowBox[{"u", "[", 
     RowBox[{"x", ",", "t"}], "]"}], "\[Rule]", 
    RowBox[{
     FractionBox[
      RowBox[{"5", " ", 
       SubscriptBox["\[ScriptCapitalA]", 
        RowBox[{"-", "1"}]]}], "2"], "+", 
     SubscriptBox["\[ScriptCapitalA]", "0"]}]}]}], "}"}]], "Output",
 CellChangeTimes->{{3.9891160498479805`*^9, 3.989116066190359*^9}, 
   3.990357332940487*^9},
 CellLabel->"Out[1]=",
