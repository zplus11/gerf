 CellLabel->"In[5]:=",
 CellID->291463673,ExpressionUUID->"76a92ada-9abe-5c4f-8e86-7d0d5246fb7c"],

Cell[BoxData[
 FractionBox[
  RowBox[{"\[ImaginaryI]", " ", 
   RowBox[{"(", 
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{
       RowBox[{"-", "\[ImaginaryI]"}], " ", "x"}]], "-", 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"\[ImaginaryI]", " ", "x"}]]}], ")"}]}], 
  RowBox[{
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{
     RowBox[{"-", "\[ImaginaryI]"}], " ", "x"}]], "+", 
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{"\[ImaginaryI]", " ", "x"}]]}]]], "Output",
 CellChangeTimes->{3.989114725379616*^9, 3.9903514731758823`*^9, 
  3.99035722710141*^9, 3.9903573249608097`*^9, 3.9905172574210396`*^9},
 CellLabel->"Out[5]=",
