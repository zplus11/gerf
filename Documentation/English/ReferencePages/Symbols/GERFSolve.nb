Cell["Obtain the solution sets as well:", "ExampleText",
 CellChangeTimes->{{3.983938838357931*^9, 3.9839388438900414`*^9}},
 CellID->61775799,ExpressionUUID->"52436909-44fa-604e-9603-3a1b23bd4aee"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"sols", "=", 
  RowBox[{"GERFSolve", "[", 
   RowBox[{"burgers", ",", 
    RowBox[{"u", "[", 
     RowBox[{"x", ",", "t"}], "]"}], ",", 
    RowBox[{"\"\<OutputMode\>\"", "->", "All"}]}], "]"}]}]], "Input",
 TaggingRules->{},
 CellChangeTimes->{{3.9839355966771736`*^9, 3.983935604235262*^9}, {
   3.9839361741267166`*^9, 3.983936180798403*^9}, {3.983936253651993*^9, 
   3.9839362570471096`*^9}, 3.983936422614149*^9, {3.9839365037164345`*^9, 
   3.9839365194834557`*^9}, {3.983936562808464*^9, 3.983936568452091*^9}, {
   3.983936836153595*^9, 3.983936842617111*^9}, {3.9891146037259426`*^9, 
   3.9891146048715305`*^9}},
 CellLabel->"In[4]:=",
 CellID->158129589,ExpressionUUID->"972cb961-4085-9542-9090-64b4d5b60fec"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\[Nu]", "\[Rule]", 
        FractionBox[
         SubscriptBox["\[ScriptCapitalA]", "1"], 
         RowBox[{"2", " ", 
          SubscriptBox["\[ScriptW]", "x"]}]]}], ",", 
       RowBox[{
        SubscriptBox["\[ScriptCapitalA]", 
         RowBox[{"-", "1"}]], "\[Rule]", "0"}], ",", 
       RowBox[{
        SubscriptBox["\[ScriptW]", "t"], "\[Rule]", 
        RowBox[{
         FractionBox["1", "2"], " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{"-", "2"}], " ", 
            SubscriptBox["\[ScriptCapitalA]", "0"], " ", 
            SubscriptBox["\[ScriptW]", "x"]}], "-", 
           RowBox[{
            SubscriptBox["\[ScriptCapitalA]", "1"], " ", 
            SubscriptBox["\[ScriptW]", "x"]}]}], ")"}]}]}]}], "}"}], ",", 
     RowBox[{
      RowBox[{"u", "[", 
       RowBox[{"x", ",", "t"}], "]"}], "\[Rule]", 
      RowBox[{
       SubscriptBox["\[ScriptCapitalA]", "0"], "+", 
       FractionBox[
        SubscriptBox["\[ScriptCapitalA]", "1"], 
        RowBox[{"1", "+", 
         SuperscriptBox["\[ExponentialE]", 
          RowBox[{
           RowBox[{"x", " ", 
            SubscriptBox["\[ScriptW]", "x"]}], "+", 
           RowBox[{
            FractionBox["1", "2"], " ", "t", " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{
               RowBox[{"-", "2"}], " ", 
               SubscriptBox["\[ScriptCapitalA]", "0"], " ", 
               SubscriptBox["\[ScriptW]", "x"]}], "-", 
              RowBox[{
               SubscriptBox["\[ScriptCapitalA]", "1"], " ", 
               SubscriptBox["\[ScriptW]", "x"]}]}], ")"}]}]}]]}]]}]}]}], 
    "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        SubscriptBox["\[ScriptCapitalA]", 
         RowBox[{"-", "1"}]], "\[Rule]", "0"}], ",", 
       RowBox[{
        SubscriptBox["\[ScriptCapitalA]", "1"], "\[Rule]", "0"}], ",", 
       RowBox[{
        SubscriptBox["\[ScriptW]", "t"], "\[Rule]", 
        RowBox[{
         SubscriptBox["\[ScriptW]", "x"], " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", 
            SubscriptBox["\[ScriptCapitalA]", "0"]}], "+", 
           RowBox[{"\[Nu]", " ", 
            SubscriptBox["\[ScriptW]", "x"]}]}], ")"}]}]}]}], "}"}], ",", 
     RowBox[{
      RowBox[{"u", "[", 
       RowBox[{"x", ",", "t"}], "]"}], "\[Rule]", 
      SubscriptBox["\[ScriptCapitalA]", "0"]}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        SubscriptBox["\[ScriptCapitalA]", "1"], "\[Rule]", 
        SubscriptBox["\[ScriptCapitalA]", 
         RowBox[{"-", "1"}]]}], ",", 
       RowBox[{
        SubscriptBox["\[ScriptW]", "t"], "\[Rule]", "0"}], ",", 
       RowBox[{
        SubscriptBox["\[ScriptW]", "x"], "\[Rule]", "0"}]}], "}"}], ",", 
     RowBox[{
      RowBox[{"u", "[", 
       RowBox[{"x", ",", "t"}], "]"}], "\[Rule]", 
      RowBox[{
       FractionBox[
        RowBox[{"5", " ", 
         SubscriptBox["\[ScriptCapitalA]", 
          RowBox[{"-", "1"}]]}], "2"], "+", 
       SubscriptBox["\[ScriptCapitalA]", "0"]}]}]}], "}"}]}], "}"}]], "Output",
 TaggingRules->{},
 CellChangeTimes->{
  3.9839356046127415`*^9, 3.9839360332859592`*^9, {3.9839362547361145`*^9, 
   3.9839362577680492`*^9}, {3.983936424155836*^9, 3.9839364337008533`*^9}, 
   3.9839364663554516`*^9, {3.983936502342499*^9, 3.9839365139051266`*^9}, {
   3.9839365607154274`*^9, 3.9839365692192764`*^9}, {3.983936623756386*^9, 
   3.98393663112916*^9}, {3.983936747774954*^9, 3.9839367718174973`*^9}, 
   3.9839368433083897`*^9, 3.9839385955392723`*^9, 3.983946393954916*^9, 
   3.9839469926946316`*^9, 3.983951304904169*^9, 3.989114605391262*^9, 
