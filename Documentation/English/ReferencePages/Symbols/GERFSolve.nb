Cell[BoxData[
 RowBox[{
  RowBox[{"burgers", "=", 
   RowBox[{
    RowBox[{
     RowBox[{
      SubscriptBox["\[PartialD]", "t"], 
      RowBox[{"u", "[", 
       RowBox[{"x", ",", "t"}], "]"}]}], "+", 
     RowBox[{
      RowBox[{"u", "[", 
       RowBox[{"x", ",", "t"}], "]"}], 
      RowBox[{
       SubscriptBox["\[PartialD]", "x"], 
       RowBox[{"u", "[", 
        RowBox[{"x", ",", "t"}], "]"}]}]}], "-", 
     RowBox[{"\[Nu]", " ", 
      RowBox[{
       SubscriptBox["\[PartialD]", 
        RowBox[{"x", ",", "x"}]], 
       RowBox[{"u", "[", 
        RowBox[{"x", ",", "t"}], "]"}]}]}]}], "==", "0"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9891157945700207`*^9, 3.98911580340452*^9}},
 CellLabel->"In[1]:=",
 CellID->5385389,ExpressionUUID->"5f502a34-e64d-e940-8511-cd68ed29fb83"],

Cell["Solving it with default value returns:", "ExampleText",
 CellChangeTimes->{{3.9891158074007015`*^9, 3.9891158142840137`*^9}, 
   3.989115850924679*^9},
 CellID->90352388,ExpressionUUID->"90044aa7-560e-7d4a-ac72-bcbc223737d8"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"GERFSolve", "[", 
  RowBox[{"burgers", ",", 
   RowBox[{"u", "[", 
    RowBox[{"x", ",", "t"}], "]"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.989115815801935*^9, 3.9891158197382584`*^9}},
 CellLabel->"In[2]:=",
 CellID->762382597,ExpressionUUID->"074384ad-b91d-d14a-8575-be825283933a"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"u", "[", 
     RowBox[{"x", ",", "t"}], "]"}], "\[Rule]", 
    RowBox[{
     SubscriptBox["\[ScriptCapitalA]", "0"], "+", 
     FractionBox[
      RowBox[{"2", " ", "\[Nu]", " ", 
       SubscriptBox["\[ScriptW]", "x"]}], 
      RowBox[{"1", "+", 
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{
         RowBox[{"x", " ", 
          SubscriptBox["\[ScriptW]", "x"]}], "+", 
         RowBox[{"t", " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{
             RowBox[{"-", 
              SubscriptBox["\[ScriptCapitalA]", "0"]}], " ", 
             SubscriptBox["\[ScriptW]", "x"]}], "-", 
            RowBox[{"\[Nu]", " ", 
             SubsuperscriptBox["\[ScriptW]", "x", "2"]}]}], ")"}]}]}]]}]]}]}],
    "}"}], "}"}]], "Output",
 CellChangeTimes->{3.9891158203047657`*^9, 3.9903515058449*^9, 
  3.9903572986814804`*^9, 3.990517244975775*^9},
 CellLabel->"Out[2]=",
 CellID->165403177,ExpressionUUID->"f6bcd04e-6543-0942-8035-fe4a8ff8275f"]
}, Open  ]],

Cell["Whereas a different rational function gives:", "ExampleText",
 CellChangeTimes->{{3.9891158216344604`*^9, 3.989115854140297*^9}},
 CellID->400879093,ExpressionUUID->"5e8aeae0-e935-3240-92fb-03fcbf771b6a"],

