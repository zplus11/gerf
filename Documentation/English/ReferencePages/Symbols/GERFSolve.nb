   StyleBox["lhs", "TI"], "=", 
   StyleBox["rhs", "TI"]}]], "InlineFormula",ExpressionUUID->
  "b712c3ef-96c9-f545-ad47-6f3560a1acbe"],
 " must be a single integral order NLPDE."
}], "Notes",
