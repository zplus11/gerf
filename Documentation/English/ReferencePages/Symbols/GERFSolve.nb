   "f53ac3ad-8c53-af44-9d61-f743d9b997d1"],
  $Line = 0; Null]], "ExampleSubsection",
 CellChangeTimes->{{3.989115915898161*^9, 3.989115918371372*^9}},
 CellID->170463323,ExpressionUUID->"71c46a48-217a-d949-b9a3-eaba615e1838"],

Cell[BoxData[
 RowBox[{
  RowBox[{"burgers", "=", 
   RowBox[{
    RowBox[{
     RowBox[{
      SubscriptBox["\[PartialD]", "t"], 
      RowBox[{"u", "[", 
       RowBox[{"x", ",", "t"}], "]"}]}], "+", 
     RowBox[{
      RowBox[{"u", "[", 
       RowBox[{"x", ",", "t"}], "]"}], 
      RowBox[{
       SubscriptBox["\[PartialD]", "x"], 
       RowBox[{"u", "[", 
        RowBox[{"x", ",", "t"}], "]"}]}]}], "-", 
     RowBox[{"\[Nu]", " ", 
      RowBox[{
       SubscriptBox["\[PartialD]", 
        RowBox[{"x", ",", "x"}]], 
       RowBox[{"u", "[", 
        RowBox[{"x", ",", "t"}], "]"}]}]}]}], "==", "0"}]}], ";"}]], "Input",
 CellLabel->"In[1]:=",
 CellID->160273509,ExpressionUUID->"4e14a992-6283-7c44-b168-48b9feb446a7"],

Cell["Wave constants can be provided using this option:", "ExampleText",
 CellChangeTimes->{{3.989116012164818*^9, 3.9891160225673065`*^9}},
 CellID->599540742,ExpressionUUID->"262c9b29-d80e-8b42-a936-78eefac04f5e"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"GERFSolve", "[", 
  RowBox[{"burgers", ",", 
   RowBox[{"u", "[", 
    RowBox[{"x", ",", "t"}], "]"}], ",", 
   RowBox[{"\"\<WaveConstants\>\"", "->", 
    RowBox[{"{", 
     RowBox[{"1", ",", 
      RowBox[{"-", "c"}]}], "}"}]}]}], "]"}]], "Input",
 CellChangeTimes->{{3.9891159354111233`*^9, 3.989115949542507*^9}},
 CellLabel->"In[2]:=",
 CellID->224572363,ExpressionUUID->"638ebb30-48e5-7249-b414-be5461814dfe"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"u", "[", 
     RowBox[{"x", ",", "t"}], "]"}], "\[Rule]", 
    RowBox[{"c", "-", "\[Nu]", "+", 
     FractionBox[
      RowBox[{"2", " ", "\[Nu]"}], 
      RowBox[{"1", "+", 
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{
         RowBox[{
          RowBox[{"-", "c"}], " ", "t"}], "+", "x"}]]}]]}]}], ",", 
   RowBox[{
    RowBox[{"u", "[", 
     RowBox[{"x", ",", "t"}], "]"}], "\[Rule]", 
    RowBox[{"c", "+", "\[Nu]"}]}]}], "}"}]], "Output",
 CellChangeTimes->{3.9891159501547585`*^9},
 CellLabel->"Out[2]=",
 CellID->66423163,ExpressionUUID->"5437bf18-bdf2-3443-a760-7872ce8659da"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 InterpretationBox[Cell[
  "\"BalanceConstant\"", "ExampleSubsection",ExpressionUUID->
   "f3761318-33e7-ca4e-a8f8-0b1a121b7300"],
  $Line = 0; Null]], "ExampleSubsection",
 CellChangeTimes->{{3.989115915898161*^9, 3.989115918371372*^9}, {
  3.989116030831623*^9, 3.9891160327863083`*^9}},
 CellID->160991384,ExpressionUUID->"b1481a06-94dc-0d4d-8941-7a3461d01f91"],

Cell["\<\
Ordinarily, the balance constant is calculated automatically:\
\>", "ExampleText",
 CellChangeTimes->{{3.9891160347878056`*^9, 3.989116045035307*^9}, 
   3.989116194900429*^9},
 CellID->20358894,ExpressionUUID->"aa2cf430-c306-9948-b32c-a3b5cbc6d254"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"GERFSolve", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      SubscriptBox["\[PartialD]", "t"], 
      RowBox[{"u", "[", 
       RowBox[{"x", ",", "t"}], "]"}]}], "+", 
     RowBox[{
      RowBox[{"u", "[", 
       RowBox[{"x", ",", "t"}], "]"}], 
      RowBox[{
       SubscriptBox["\[PartialD]", "x"], 
       RowBox[{"u", "[", 
        RowBox[{"x", ",", "t"}], "]"}]}]}], "-", 
     RowBox[{"\[Nu]", " ", 
      RowBox[{
       SubscriptBox["\[PartialD]", 
        RowBox[{"x", ",", "x"}]], 
       RowBox[{"u", "[", 
        RowBox[{"x", ",", "t"}], "]"}]}]}]}], "==", "0"}], ",", 
   RowBox[{"u", "[", 
    RowBox[{"x", ",", "t"}], "]"}], ",", 
   RowBox[{"\"\<BalanceConstant\>\"", "->", "Automatic"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.9891160566127644`*^9, 3.9891160657670536`*^9}},
 CellLabel->"In[2]:=",
 CellID->20034340,ExpressionUUID->"38e3d88c-bbd0-1748-b88b-2673149584d2"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"u", "[", 
     RowBox[{"x", ",", "t"}], "]"}], "\[Rule]", 
    SubscriptBox["\[ScriptCapitalA]", "0"]}], ",", 
   RowBox[{
    RowBox[{"u", "[", 
     RowBox[{"x", ",", "t"}], "]"}], "\[Rule]", 
    RowBox[{
     FractionBox[
      RowBox[{"5", " ", 
       SubscriptBox["\[ScriptCapitalA]", 
        RowBox[{"-", "1"}]]}], "2"], "+", 
     SubscriptBox["\[ScriptCapitalA]", "0"]}]}], ",", 
   RowBox[{
    RowBox[{"u", "[", 
     RowBox[{"x", ",", "t"}], "]"}], "\[Rule]", 
    RowBox[{
     SubscriptBox["\[ScriptCapitalA]", "0"], "+", 
     FractionBox[
      RowBox[{"2", " ", "\[Nu]", " ", 
       SubscriptBox["\[ScriptW]", "x"]}], 
      RowBox[{"1", "+", 
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{
         RowBox[{"x", " ", 
          SubscriptBox["\[ScriptW]", "x"]}], "+", 
         RowBox[{"t", " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{
             RowBox[{"-", 
              SubscriptBox["\[ScriptCapitalA]", "0"]}], " ", 
             SubscriptBox["\[ScriptW]", "x"]}], "-", 
            RowBox[{"\[Nu]", " ", 
             SubsuperscriptBox["\[ScriptW]", "x", "2"]}]}], 
           ")"}]}]}]]}]]}]}]}], "}"}]], "Output",
 CellChangeTimes->{{3.9891160498479805`*^9, 3.989116066190359*^9}},
 CellLabel->"Out[2]=",
 CellID->195291394,ExpressionUUID->"5d8b8bb7-d688-d24f-83f9-3dd4e6e1c048"]
}, Open  ]],

Cell["But a higher value can be provided:", "ExampleText",
 CellChangeTimes->{{3.9891160709764214`*^9, 3.989116075763571*^9}},
 CellID->396431571,ExpressionUUID->"79a1805c-a96e-7f45-b4f1-6ad1b74d02ce"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"GERFSolve", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      SubscriptBox["\[PartialD]", "t"], 
      RowBox[{"u", "[", 
       RowBox[{"x", ",", "t"}], "]"}]}], "+", 
     RowBox[{
      RowBox[{"u", "[", 
       RowBox[{"x", ",", "t"}], "]"}], 
      RowBox[{
       SubscriptBox["\[PartialD]", "x"], 
       RowBox[{"u", "[", 
        RowBox[{"x", ",", "t"}], "]"}]}]}], "-", 
     RowBox[{"\[Nu]", " ", 
      RowBox[{
       SubscriptBox["\[PartialD]", 
        RowBox[{"x", ",", "x"}]], 
       RowBox[{"u", "[", 
        RowBox[{"x", ",", "t"}], "]"}]}]}]}], "==", "0"}], ",", 
   RowBox[{"u", "[", 
    RowBox[{"x", ",", "t"}], "]"}], ",", 
   RowBox[{"\"\<BalanceConstant\>\"", "->", "2"}]}], "]"}]], "Input",
 CellChangeTimes->{3.989116077902155*^9},
 CellLabel->"In[3]:=",
 CellID->548171228,ExpressionUUID->"fa092ff2-54e2-8d49-a75d-eb3304928ebf"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"u", "[", 
     RowBox[{"x", ",", "t"}], "]"}], "\[Rule]", 
    RowBox[{
     RowBox[{"4", " ", 
      SubscriptBox["\[ScriptCapitalA]", 
       RowBox[{"-", "2"}]]}], "+", 
     RowBox[{"2", " ", 
      SubscriptBox["\[ScriptCapitalA]", 
       RowBox[{"-", "1"}]]}], "+", 
     SubscriptBox["\[ScriptCapitalA]", "0"], "+", 
     RowBox[{
      FractionBox["1", "4"], " ", 
      RowBox[{"(", 
       RowBox[{
        SubscriptBox["\[ScriptCapitalA]", 
         RowBox[{"-", "2"}]], "+", 
        FractionBox[
         SubscriptBox["\[ScriptCapitalA]", 
          RowBox[{"-", "1"}]], "2"], "-", 
        FractionBox[
         SubscriptBox["\[ScriptCapitalA]", "1"], "2"]}], ")"}]}], "+", 
     FractionBox[
      SubscriptBox["\[ScriptCapitalA]", "1"], "2"]}]}], ",", 
   RowBox[{
    RowBox[{"u", "[", 
     RowBox[{"x", ",", "t"}], "]"}], "\[Rule]", 
    RowBox[{
     RowBox[{"2", " ", 
      SubscriptBox["\[ScriptCapitalA]", 
       RowBox[{"-", "1"}]]}], "+", 
     SubscriptBox["\[ScriptCapitalA]", "0"], "+", 
     RowBox[{
      FractionBox["1", "4"], " ", 
      RowBox[{"(", 
       RowBox[{
        FractionBox[
         SubscriptBox["\[ScriptCapitalA]", 
          RowBox[{"-", "1"}]], "2"], "-", 
        FractionBox[
         SubscriptBox["\[ScriptCapitalA]", "1"], "2"]}], ")"}]}], "+", 
     FractionBox[
      SubscriptBox["\[ScriptCapitalA]", "1"], "2"]}]}], ",", 
   RowBox[{
    RowBox[{"u", "[", 
     RowBox[{"x", ",", "t"}], "]"}], "\[Rule]", 
    RowBox[{
     SubscriptBox["\[ScriptCapitalA]", "0"], "+", 
     FractionBox[
      RowBox[{"2", " ", "\[Nu]", " ", 
       SubscriptBox["\[ScriptW]", "x"]}], 
      RowBox[{"1", "+", 
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{
         RowBox[{"x", " ", 
          SubscriptBox["\[ScriptW]", "x"]}], "+", 
         RowBox[{"t", " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{
             RowBox[{"-", 
              SubscriptBox["\[ScriptCapitalA]", "0"]}], " ", 
             SubscriptBox["\[ScriptW]", "x"]}], "-", 
            RowBox[{"\[Nu]", " ", 
             SubsuperscriptBox["\[ScriptW]", "x", "2"]}]}], ")"}]}]}]]}]]}]}],
    ",", 
   RowBox[{
    RowBox[{"u", "[", 
     RowBox[{"x", ",", "t"}], "]"}], "\[Rule]", 
    SubscriptBox["\[ScriptCapitalA]", "0"]}], ",", 
   RowBox[{
    RowBox[{"u", "[", 
     RowBox[{"x", ",", "t"}], "]"}], "\[Rule]", 
    SubscriptBox["\[ScriptCapitalA]", "0"]}]}], "}"}]], "Output",
 CellChangeTimes->{3.9891160788748856`*^9},
 CellLabel->"Out[3]=",
 CellID->335368766,ExpressionUUID->"bdcf07a3-c543-5b4b-9a51-d9a62aca0b26"]
}, Open  ]]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 InterpretationBox[Cell[
  "Applications", "ExampleSection",ExpressionUUID->
   "48c48e3f-77a5-2a45-8441-9a87267a4e4c"],
  $Line = 0; Null]], "ExampleSection",
 CellID->779239918,ExpressionUUID->"1430ce75-4785-fd4f-beb8-7ea774aa72b8"],

Cell["\<\
Solving the (3\[ThinSpace]+\[ThinSpace]1)-dimensional Hirota\[Dash]Satsuma\
\[Dash]Ito-Like equation given as:\
\>", "ExampleText",
 CellChangeTimes->{{3.989116688767229*^9, 3.9891166934255238`*^9}},
 CellID->550057579,ExpressionUUID->"65e42dd6-84fa-e24d-8bd9-442a9aaa71a5"],

Cell[BoxData[
 RowBox[{
  RowBox[{"eq", "=", 
   RowBox[{
    RowBox[{
     RowBox[{
      SubscriptBox["\[PartialD]", 
       RowBox[{"x", ",", "x", ",", "x", ",", "t"}]], 
      RowBox[{"u", "[", 
       RowBox[{"x", ",", "y", ",", "z", ",", "t"}], "]"}]}], "+", 
     RowBox[{"3", 
      RowBox[{
       SubscriptBox["\[PartialD]", 
        RowBox[{"x", ",", "t"}]], 
       RowBox[{"u", "[", 
        RowBox[{"x", ",", "y", ",", "z", ",", "t"}], "]"}]}], 
      RowBox[{
       SubscriptBox["\[PartialD]", "x"], 
       RowBox[{"u", "[", 
        RowBox[{"x", ",", "y", ",", "z", ",", "t"}], "]"}]}]}], "+", 
     RowBox[{"3", 
      RowBox[{
       SubscriptBox["\[PartialD]", 
        RowBox[{"x", ",", "x"}]], 
       RowBox[{"u", "[", 
        RowBox[{"x", ",", "y", ",", "z", ",", "t"}], "]"}]}], 
      RowBox[{
       SubscriptBox["\[PartialD]", "t"], 
       RowBox[{"u", "[", 
        RowBox[{"x", ",", "y", ",", "z", ",", "t"}], "]"}]}]}], "+", 
     RowBox[{"a", " ", 
      RowBox[{
       SubscriptBox["\[PartialD]", 
        RowBox[{"y", ",", "t"}]], 
       RowBox[{"u", "[", 
        RowBox[{"x", ",", "y", ",", "z", ",", "t"}], "]"}]}]}], "+", 
     RowBox[{"b", " ", 
      RowBox[{
       SubscriptBox["\[PartialD]", 
        RowBox[{"z", ",", "t"}]], 
       RowBox[{"u", "[", 
        RowBox[{"x", ",", "y", ",", "z", ",", "t"}], "]"}]}]}]}], "==", 
    "0"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9891163148919773`*^9, 3.989116372152834*^9}},
 CellLabel->"In[1]:=",
 CellID->31552907,ExpressionUUID->"cb5c7425-a26b-d741-bf51-1cef428bbeb5"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"GERFSolve", "[", "\[IndentingNewLine]", 
   RowBox[{"eq", ",", 
    RowBox[{"u", "[", 
     RowBox[{"x", ",", "y", ",", "z", ",", "t"}], "]"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"\"\<WaveConstants\>\"", "->", 
     RowBox[{"{", 
      RowBox[{"\[Alpha]", ",", "\[Beta]", ",", "\[Gamma]", ",", 
       RowBox[{"-", "p"}]}], "}"}]}], ",", "\[IndentingNewLine]", 
    RowBox[{"\"\<RationalFunction\>\"", "->", 
     RowBox[{"(", 
      RowBox[{
       FractionBox[
        RowBox[{
         RowBox[{"-", "3"}], "-", 
         SuperscriptBox["E", "#"]}], 
        RowBox[{"1", "+", 
         SuperscriptBox["E", "#"]}]], "&"}], ")"}]}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"\"\<OutputMode\>\"", "->", "All"}]}], "\[IndentingNewLine]", 
   "]"}], "[", 
  RowBox[{"[", "6", "]"}], "]"}]], "Input",
 CellChangeTimes->{{3.989116392826706*^9, 3.9891165063968983`*^9}, {
  3.9891166128635807`*^9, 3.989116631482937*^9}},
 CellLabel->"In[7]:=",
 CellID->501497221,ExpressionUUID->"c56ac125-c557-4341-8c71-710fefb38c25"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\[Gamma]", "\[Rule]", 
      FractionBox[
       RowBox[{
        RowBox[{"-", 
         SuperscriptBox["\[Alpha]", "3"]}], "-", 
        RowBox[{"a", " ", "\[Beta]"}]}], "b"]}], ",", 
     RowBox[{
      SubscriptBox["\[ScriptCapitalA]", 
       RowBox[{"-", "1"}]], "\[Rule]", 
      RowBox[{
       RowBox[{"-", "3"}], " ", "\[Alpha]"}]}], ",", 
     RowBox[{
      SubscriptBox["\[ScriptCapitalA]", "1"], "\[Rule]", "0"}]}], "}"}], ",", 
   RowBox[{
    RowBox[{"u", "[", 
     RowBox[{"x", ",", "y", ",", "z", ",", "t"}], "]"}], "\[Rule]", 
    RowBox[{
     RowBox[{"-", 
      FractionBox[
       RowBox[{"3", " ", 
        RowBox[{"(", 
         RowBox[{"1", "+", 
          SuperscriptBox["\[ExponentialE]", 
           RowBox[{
            RowBox[{
             RowBox[{"-", "p"}], " ", "t"}], "+", 
            RowBox[{"x", " ", "\[Alpha]"}], "+", 
            RowBox[{"y", " ", "\[Beta]"}], "+", 
            FractionBox[
             RowBox[{"z", " ", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{"-", 
                 SuperscriptBox["\[Alpha]", "3"]}], "-", 
                RowBox[{"a", " ", "\[Beta]"}]}], ")"}]}], "b"]}]]}], ")"}], " ",
         "\[Alpha]"}], 
       RowBox[{
        RowBox[{"-", "3"}], "-", 
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{
          RowBox[{
           RowBox[{"-", "p"}], " ", "t"}], "+", 
          RowBox[{"x", " ", "\[Alpha]"}], "+", 
          RowBox[{"y", " ", "\[Beta]"}], "+", 
          FractionBox[
           RowBox[{"z", " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"-", 
               SuperscriptBox["\[Alpha]", "3"]}], "-", 
              RowBox[{"a", " ", "\[Beta]"}]}], ")"}]}], "b"]}]]}]]}], "+", 
     SubscriptBox["\[ScriptCapitalA]", "0"]}]}]}], "}"}]], "Output",
 CellChangeTimes->{{3.9891164505902386`*^9, 3.989116476905882*^9}, 
   3.98911650752462*^9, {3.9891166164370823`*^9, 3.9891166326060143`*^9}},
 CellLabel->"Out[7]=",
 CellID->277706493,ExpressionUUID->"9f74dfd5-e33d-9546-a33d-8c16f8a4026d"]
}, Open  ]],

Cell[TextData[{
 "This solution is exactly as obtained by Mia et al. (",
 ButtonBox["https://doi.org/10.1080/25765299.2026.2614167",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1080/25765299.2026.2614167"], None},
  ButtonNote->"https://doi.org/10.1080/25765299.2026.2614167"],
 ") in their equation (3.7)."
}], "ExampleText",
