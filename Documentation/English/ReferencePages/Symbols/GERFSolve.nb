Cell[TextData[{
 "Solve a nonlinear ODE using ",
 Cell[BoxData[
  ButtonBox["GERFSolve",
   BaseStyle->"Link",
   ButtonData->"paclet:Taggar/GERF/ref/GERFSolve"]], "InlineFormula",
  ExpressionUUID->"17a4b220-ed8c-004d-a1ce-f98dbdfdf483"],
 " using a trivial wave transformation:"
}], "ExampleText",
 CellChangeTimes->{{3.9904018854431076`*^9, 3.9904018980072594`*^9}, {
  3.9904021235630035`*^9, 3.9904021286659584`*^9}},
 CellID->102207701,ExpressionUUID->"3fe89d79-62ca-0b47-b958-97768f581d17"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"GERFSolve", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"u", "''"}], "[", "\[Eta]", "]"}], "+", 
     RowBox[{"3", 
      SuperscriptBox[
       RowBox[{"u", "[", "\[Eta]", "]"}], "2"]}], "-", 
     RowBox[{"2", 
      SuperscriptBox[
       RowBox[{"u", "[", "\[Eta]", "]"}], "3"]}], "-", 
     RowBox[{"u", "[", "\[Eta]", "]"}]}], "==", "0"}], ",", 
   RowBox[{"u", "[", "\[Eta]", "]"}], ",", 
   RowBox[{"\"\<WaveConstants\>\"", "->", 
    RowBox[{"{", "1", "}"}]}]}], "]"}]], "Input",
 CellChangeTimes->{{3.990401934907419*^9, 3.990402009462473*^9}},
 CellLabel->"In[2]:=",
 CellID->217465545,ExpressionUUID->"19a559a7-40b6-e449-a4eb-a5f9b49d9140"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"u", "[", "\[Eta]", "]"}], "\[Rule]", 
    FractionBox["1", "2"]}], ",", 
   RowBox[{
    RowBox[{"u", "[", "\[Eta]", "]"}], "\[Rule]", 
    FractionBox["1", 
     RowBox[{"1", "+", 
      SuperscriptBox["\[ExponentialE]", "\[Eta]"]}]]}], ",", 
   RowBox[{
    RowBox[{"u", "[", "\[Eta]", "]"}], "\[Rule]", "1"}], ",", 
   RowBox[{
    RowBox[{"u", "[", "\[Eta]", "]"}], "\[Rule]", 
    RowBox[{"1", "-", 
     FractionBox["1", 
      RowBox[{"1", "+", 
       SuperscriptBox["\[ExponentialE]", "\[Eta]"]}]]}]}]}], "}"}]], "Output",
 CellChangeTimes->{{3.990401991106064*^9, 3.9904020099957333`*^9}},
 CellLabel->"Out[2]=",
 CellID->58877196,ExpressionUUID->"88696890-f748-fa45-b6d1-79bd080eaa63"]
}, Open  ]]
}, Open  ]]
}, Open  ]],

