Cell[BoxData[
 RowBox[{"GERFSolve", "[", 
  RowBox[{"burgers", ",", 
   RowBox[{"u", "[", 
    RowBox[{"x", ",", "t"}], "]"}], ",", 
   RowBox[{"\"\<RationalFunction\>\"", "->", "Tan"}]}], "]"}]], "Input",
