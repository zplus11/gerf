Cell["Solve the fractional version of burgers equation:", "ExampleText",
 CellChangeTimes->{{3.9891153589257927`*^9, 3.989115367986307*^9}},
 CellID->3020522,ExpressionUUID->"533f94a2-3dac-f74a-80e5-e2096dbcf4ef"],

Cell[BoxData[
 RowBox[{
  RowBox[{"fb", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"FractionalD", "[", 
      RowBox[{
       RowBox[{"u", "[", 
        RowBox[{"x", ",", "t"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"t", ",", "\[Alpha]"}], "}"}]}], "]"}], "+", 
     RowBox[{"\[Beta]", " ", 
      SuperscriptBox[
       RowBox[{"u", "[", 
        RowBox[{"x", ",", "t"}], "]"}], "\[Delta]"], 
      RowBox[{
       SubscriptBox["\[PartialD]", "x"], 
       RowBox[{"u", "[", 
        RowBox[{"x", ",", "t"}], "]"}]}]}], "-", 
     RowBox[{"\[Nu]", " ", 
      RowBox[{
       SubscriptBox["\[PartialD]", 
        RowBox[{"x", ",", "x"}]], 
       RowBox[{"u", "[", 
        RowBox[{"x", ",", "t"}], "]"}]}]}]}], "==", 
    RowBox[{"\[Gamma]", " ", 
     RowBox[{"u", "[", 
      RowBox[{"x", ",", "t"}], "]"}], 
     RowBox[{"(", 
      RowBox[{"1", "-", 
       SuperscriptBox[
        RowBox[{"u", "[", 
         RowBox[{"x", ",", "t"}], "]"}], "2"]}], ")"}]}]}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9904022686349144`*^9, 3.990402278604065*^9}, {
  3.9904023490512447`*^9, 3.9904023532250576`*^9}, {3.9904026096992264`*^9, 
  3.990402612879816*^9}},
 CellLabel->"In[5]:=",
 CellID->516204041,ExpressionUUID->"ed92d5d4-7dd3-904d-81ef-d5b92ea60dbc"],

Cell[TextData[{
 "Using ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Delta]", "TR"], "=", "1"}]], "InlineFormula",ExpressionUUID->
  "ab55f62f-dfa9-534f-98be-7f17ee45ae92"],
 ", we use ",
 Cell[BoxData[
  ButtonBox["GERFSolve",
   BaseStyle->"Link",
   ButtonData->"paclet:Taggar/GERF/ref/GERFSolve"]], "InlineFormula",
  ExpressionUUID->"ac732578-af14-494b-89b6-2ba480d4b981"],
 ":"
}], "ExampleText",
 CellChangeTimes->{{3.990402288541872*^9, 3.990402313590975*^9}, {
   3.990402418135887*^9, 3.990402447374487*^9}, 3.9904024902554703`*^9},
 CellID->504491264,ExpressionUUID->"ed7e5739-5825-0e4e-9d92-63fd2662fd0f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"GERFSolve", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"fb", "/.", 
    RowBox[{"\[Delta]", "->", "1"}]}], ",", "\[IndentingNewLine]", 
   RowBox[{"u", "[", 
    RowBox[{"x", ",", "t"}], "]"}], ",", 
   RowBox[{"\"\<WaveConstants\>\"", "->", 
    RowBox[{"{", 
     RowBox[{"1", ",", 
      RowBox[{"-", "c"}]}], "}"}]}]}], "\[IndentingNewLine]", "]"}]], "Input",
 CellChangeTimes->{{3.990402215172842*^9, 3.9904022516350327`*^9}, {
  3.990402318176855*^9, 3.9904023230092793`*^9}, {3.990402363006256*^9, 
  3.9904023639941826`*^9}, {3.9904023957356663`*^9, 3.990402449310192*^9}, {
  3.990517347710682*^9, 3.990517370245064*^9}},
 CellLabel->"In[6]:=",
 CellID->61811311,ExpressionUUID->"d9839c99-6ecf-5742-b1fb-bfc2b9067afe"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
