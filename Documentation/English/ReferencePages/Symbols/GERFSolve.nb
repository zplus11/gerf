Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"u", "[", 
     RowBox[{"x", ",", "t"}], "]"}], "\[Rule]", 
    RowBox[{
     SubscriptBox["\[ScriptCapitalA]", "0"], "+", 
     FractionBox[
      RowBox[{"2", " ", "\[Nu]", " ", 
       SubscriptBox["\[ScriptW]", "x"]}], 
      RowBox[{"1", "+", 
       SuperscriptBox["\[ExponentialE]", 
