 CellLabel->"In[11]:=",
 CellID->158129589,ExpressionUUID->"972cb961-4085-9542-9090-64b4d5b60fec"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       SubscriptBox["\[ScriptCapitalA]", 
        RowBox[{"-", "1"}]], "\[Rule]", "0"}], ",", 
      RowBox[{
       SubscriptBox["\[ScriptCapitalA]", "1"], "\[Rule]", 
       RowBox[{"2", " ", "\[Nu]", " ", 
        SubscriptBox["\[ScriptW]", "x"]}]}], ",", 
      RowBox[{
       SubscriptBox["\[ScriptW]", "t"], "\[Rule]", 
       RowBox[{
        RowBox[{
         RowBox[{"-", 
          SubscriptBox["\[ScriptCapitalA]", "0"]}], " ", 
         SubscriptBox["\[ScriptW]", "x"]}], "-", 
        RowBox[{"\[Nu]", " ", 
         SubsuperscriptBox["\[ScriptW]", "x", "2"]}]}]}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"u", "[", 
       RowBox[{"x", ",", "t"}], "]"}], "\[Rule]", 
      RowBox[{
       SubscriptBox["\[ScriptCapitalA]", "0"], "+", 
       FractionBox[
        RowBox[{"2", " ", "\[Nu]", " ", 
         SubscriptBox["\[ScriptW]", "x"]}], 
        RowBox[{"1", "+", 
         SuperscriptBox["\[ExponentialE]", 
          RowBox[{
           RowBox[{"x", " ", 
            SubscriptBox["\[ScriptW]", "x"]}], "+", 
           RowBox[{"t", " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{
               RowBox[{"-", 
                SubscriptBox["\[ScriptCapitalA]", "0"]}], " ", 
               SubscriptBox["\[ScriptW]", "x"]}], "-", 
              RowBox[{"\[Nu]", " ", 
               SubsuperscriptBox["\[ScriptW]", "x", "2"]}]}], 
             ")"}]}]}]]}]]}]}], "}"}]}], "}"}], "}"}]], "Output",
 TaggingRules->{},
