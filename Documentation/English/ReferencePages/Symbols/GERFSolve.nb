      RowBox[{"u", "[", 
       RowBox[{"x", ",", "y", ",", "t"}], "]"}]}], "+", 
     RowBox[{"4", 
      RowBox[{
       SubscriptBox["\[PartialD]", "x"], 
       RowBox[{"u", "[", 
        RowBox[{"x", ",", "y", ",", "t"}], "]"}]}], 
      RowBox[{
       SubscriptBox["\[PartialD]", 
        RowBox[{"x", ",", "y"}]], 
       RowBox[{"u", "[", 
        RowBox[{"x", ",", "y", ",", "t"}], "]"}]}]}], "+", 
     RowBox[{"2", 
      RowBox[{
       SubscriptBox["\[PartialD]", 
        RowBox[{"x", ",", "x"}]], 
       RowBox[{"u", "[", 
        RowBox[{"x", ",", "y", ",", "t"}], "]"}]}], 
      RowBox[{
       SubscriptBox["\[PartialD]", "y"], 
       RowBox[{"u", "[", 
        RowBox[{"x", ",", "y", ",", "t"}], "]"}]}]}], "+", " ", 
     RowBox[{
      SubscriptBox["\[PartialD]", 
       RowBox[{"x", ",", "x", ",", "x", ",", "y"}]], 
      RowBox[{"u", "[", 
       RowBox[{"x", ",", "y", ",", "t"}], "]"}]}]}], "==", "0"}]}], 
  ";"}]], "Input",
