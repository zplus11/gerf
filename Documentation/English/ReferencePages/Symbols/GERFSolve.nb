Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"GERFSolve", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"FractionalD", "[", 
      RowBox[{
       RowBox[{"u", "[", 
        RowBox[{"x", ",", "t"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"t", ",", "\[Alpha]"}], "}"}]}], "]"}], "+", 
     RowBox[{
      RowBox[{"u", "[", 
       RowBox[{"x", ",", "t"}], "]"}], 
      RowBox[{
       SubscriptBox["\[PartialD]", "x"], 
       RowBox[{"u", "[", 
        RowBox[{"x", ",", "t"}], "]"}]}]}], "-", 
     RowBox[{"\[Nu]", " ", 
      RowBox[{
       SubscriptBox["\[PartialD]", 
        RowBox[{"x", ",", "x"}]], 
       RowBox[{"u", "[", 
        RowBox[{"x", ",", "t"}], "]"}]}]}]}], "==", "0"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"u", "[", 
    RowBox[{"x", ",", "t"}], "]"}], ",", 
   RowBox[{"\"\<WaveConstants\>\"", "->", 
    RowBox[{"{", 
     RowBox[{"1", ",", 
      RowBox[{"-", "c"}]}], "}"}]}], ",", 
   RowBox[{"\"\<RationalFunction\>\"", "->", "Tan"}]}], "\[IndentingNewLine]",
   "]"}]], "Input",
