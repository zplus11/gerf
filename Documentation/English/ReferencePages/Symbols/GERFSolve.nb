Cell[TextData[{
 "Another example,  Calogero\[Dash]Bogoyavlenskii\[Dash]Schiff equation in ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{"2", "+", "1"}], ")"}], TraditionalForm]],ExpressionUUID->
  "98e0d7b2-146e-8749-96a3-e89cfad83b6e"],
 "-dimensions:"
}], "ExampleText",
 CellChangeTimes->{{3.983938874457634*^9, 3.9839388812269096`*^9}, {
  3.9839389375979595`*^9, 3.983938942685793*^9}},
 CellID->225889266,ExpressionUUID->"5950f954-131f-2240-811a-b3df8a957a23"],

Cell[BoxData[
 RowBox[{
  RowBox[{"cbs", "=", 
   RowBox[{
    RowBox[{
     RowBox[{
      SubscriptBox["\[PartialD]", 
       RowBox[{"x", ",", "t"}]], 
      RowBox[{"u", "[", 
       RowBox[{"x", ",", "y", ",", "t"}], "]"}]}], "+", 
     RowBox[{"4", 
      RowBox[{
       SubscriptBox["\[PartialD]", "x"], 
       RowBox[{"u", "[", 
        RowBox[{"x", ",", "y", ",", "t"}], "]"}]}], 
      RowBox[{
       SubscriptBox["\[PartialD]", 
        RowBox[{"x", ",", "y"}]], 
       RowBox[{"u", "[", 
        RowBox[{"x", ",", "y", ",", "t"}], "]"}]}]}], "+", 
     RowBox[{"2", 
      RowBox[{
       SubscriptBox["\[PartialD]", 
        RowBox[{"x", ",", "x"}]], 
       RowBox[{"u", "[", 
        RowBox[{"x", ",", "y", ",", "t"}], "]"}]}], 
      RowBox[{
       SubscriptBox["\[PartialD]", "y"], 
       RowBox[{"u", "[", 
        RowBox[{"x", ",", "y", ",", "t"}], "]"}]}]}], "+", " ", 
     RowBox[{
      SubscriptBox["\[PartialD]", 
       RowBox[{"x", ",", "x", ",", "x", ",", "y"}]], 
      RowBox[{"u", "[", 
       RowBox[{"x", ",", "y", ",", "t"}], "]"}]}]}], "==", "0"}]}], 
  ";"}]], "Input",
 TaggingRules->{},
 CellLabel->"In[1]:=",
 CellID->477721499,ExpressionUUID->"f0854e88-cc75-ca4d-a8dd-b79b7a406cf2"],

Cell["Solve it:", "ExampleText",
 TaggingRules->{},
 CellChangeTimes->{{3.9839356704976196`*^9, 3.9839356741536236`*^9}},
 CellID->87489562,ExpressionUUID->"a0b8dabc-4163-c64f-9474-4305f1d047fe"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"sols", "=", 
  RowBox[{"GERFSolve", "[", 
   RowBox[{"cbs", ",", 
    RowBox[{"u", "[", 
     RowBox[{"x", ",", "y", ",", "t"}], "]"}]}], "]"}]}]], "Input",
 TaggingRules->{},
 CellChangeTimes->{{3.983935675348982*^9, 3.983935680272434*^9}, {
  3.9839358621555157`*^9, 3.983935866489809*^9}, {3.9839360139207897`*^9, 
  3.983936014046633*^9}, {3.983937085897793*^9, 3.983937086603039*^9}},
 CellLabel->"In[2]:=",
 CellID->92882555,ExpressionUUID->"8a871170-10b9-6245-8c67-ab77788d5c43"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"u", "[", 
     RowBox[{"x", ",", "y", ",", "t"}], "]"}], "\[Rule]", 
    SubscriptBox["\[ScriptCapitalA]", "0"]}], ",", 
   RowBox[{
    RowBox[{"u", "[", 
     RowBox[{"x", ",", "y", ",", "t"}], "]"}], "\[Rule]", 
    RowBox[{
     SubscriptBox["\[ScriptCapitalA]", "0"], "-", 
     FractionBox[
      RowBox[{"2", " ", 
       SubscriptBox["\[ScriptW]", "x"]}], 
      RowBox[{"1", "+", 
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{
         RowBox[{"x", " ", 
          SubscriptBox["\[ScriptW]", "x"]}], "+", 
         RowBox[{"y", " ", 
          SubscriptBox["\[ScriptW]", "y"]}], "-", 
         RowBox[{"t", " ", 
          SubsuperscriptBox["\[ScriptW]", "x", "2"], " ", 
          SubscriptBox["\[ScriptW]", "y"]}]}]]}]]}]}], ",", 
   RowBox[{
    RowBox[{"u", "[", 
     RowBox[{"x", ",", "y", ",", "t"}], "]"}], "\[Rule]", 
    RowBox[{
     FractionBox[
      SubscriptBox["\[ScriptCapitalA]", 
       RowBox[{"-", "1"}]], 
      RowBox[{"1", "+", 
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{"x", " ", 
         SubscriptBox["\[ScriptW]", "x"]}]]}]], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "+", 
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{"x", " ", 
          SubscriptBox["\[ScriptW]", "x"]}]]}], ")"}], " ", 
      SubscriptBox["\[ScriptCapitalA]", 
       RowBox[{"-", "1"}]]}], "+", 
     SubscriptBox["\[ScriptCapitalA]", "0"]}]}]}], "}"}]], "Output",
 TaggingRules->{},
 CellChangeTimes->{
  3.9839356819065685`*^9, 3.9839357210736237`*^9, {3.9839357518631554`*^9, 
   3.9839358185484314`*^9}, {3.9839358524138947`*^9, 
   3.9839358671806297`*^9}, {3.983936005387207*^9, 3.983936014655554*^9}, {
   3.9839370593230953`*^9, 3.9839370873552628`*^9}, 3.983946401553808*^9, 
   3.983951309928108*^9, 3.989114613033388*^9},
 CellLabel->"Out[2]=",
 CellID->29198034,ExpressionUUID->"90abaaf7-5b1e-b442-83ae-a99e87f6a8fc"]
}, Open  ]],

