Notebook[{

Cell[CellGroupData[{
Cell["GERFSolve", "ObjectName",
 CellID->322747057,ExpressionUUID->"5b2a6b6b-3ab9-8642-804d-c44d0def25e9"],

Cell[TextData[{
 Cell["   ", "ModInfo",ExpressionUUID->"5e8eaa3b-c1df-2e4b-af53-00b6032f754c"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["GERFSolve",
    BaseStyle->"Link",
    ButtonData->"paclet:Taggar/GERF/ref/GERFSolve"], "[", 
   RowBox[{
    RowBox[{
     StyleBox["lhs", "TI"], "=", 
     StyleBox["rhs", "TI"]}], ",", 
    RowBox[{
     StyleBox["u", "TI"], "[", 
     StyleBox["vars", "TI"], "]"}], ",", "..."}], "]"}]], "InlineFormula",
  ExpressionUUID->"f9cd0f3a-1098-2043-b55d-4431217b60c1"],
 " \[LineSeparator]solves the NLPDE given by ",
 Cell[BoxData[
  RowBox[{
   StyleBox["lhs", "TI"], "=", 
   StyleBox["rhs", "TI"]}]], "InlineFormula",ExpressionUUID->
  "f37546a9-7bbb-5643-a043-97ea9ec637ce"],
 " for ",
 Cell[BoxData[
  StyleBox[
   RowBox[{"u", "[", "vars", "]"}], "TI"]], "InlineFormula",ExpressionUUID->
  "a6911a84-240d-df49-a4b3-d52b1d8439ae"],
 " using the GERF expansion technique.\n",
 Cell["   ", "ModInfo",ExpressionUUID->"0084d340-e395-0e4e-8c34-12111366b7c2"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["GERFSolve",
    BaseStyle->"Link",
    ButtonData->"paclet:Taggar/GERF/ref/GERFSolve"], "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      SubscriptBox[
       StyleBox["eqn", "TI"], "1"], ",", 
      SubscriptBox[
       StyleBox["eqn", "TI"], "2"], ",", "...", ",", 
      SubscriptBox[
       StyleBox["eqn", "TI"], 
       StyleBox["k", "TI"]]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       SubscriptBox[
        StyleBox["u", "TI"], "1"], "[", 
       StyleBox["vars", "TI"], "]"}], ",", 
      RowBox[{
       SubscriptBox[
        StyleBox["u", "TI"], "2"], "[", 
       StyleBox["vars", "TI"], "]"}], ",", "...", ",", 
      RowBox[{
       SubscriptBox[
        StyleBox["u", "TI"], 
        StyleBox["k", "TI"]], "[", 
       StyleBox["vars", "TI"], "]"}]}], "}"}], ",", "..."}], "]"}]], 
  "InlineFormula",ExpressionUUID->"799a19f8-6db3-5148-8a72-fa3a3a1d5fa5"],
 "\[LineSeparator]solves the system of equations ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{
    SubscriptBox[
     StyleBox["eqn", "TI"], "1"], ",", 
    SubscriptBox[
     StyleBox["eqn", "TI"], "2"], ",", "...", ",", 
    SubscriptBox[
     StyleBox["eqn", "TI"], 
     StyleBox["k", "TI"]]}], "}"}]], "InlineFormula",ExpressionUUID->
  "dc2cd40f-5399-0246-a6f8-0371874aac4b"],
 " for ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{
    RowBox[{
     SubscriptBox[
      StyleBox["u", "TI"], "1"], "[", 
     StyleBox["vars", "TI"], "]"}], ",", 
    RowBox[{
     SubscriptBox[
      StyleBox["u", "TI"], "2"], "[", 
     StyleBox["vars", "TI"], "]"}], ",", "...", ",", 
    RowBox[{
     SubscriptBox[
      StyleBox["u", "TI"], 
      StyleBox["k", "TI"]], "[", 
     StyleBox["vars", "TI"], "]"}]}], "}"}]], "InlineFormula",ExpressionUUID->
  "dc254a30-be50-8c47-8e90-df8ec4576472"],
 " using GERF expansion technique."
}], "Usage",
 CellChangeTimes->{{3.9839372797049026`*^9, 3.9839373520046005`*^9}, {
  3.990518916112236*^9, 3.990519017945759*^9}},
 CellID->10018101,ExpressionUUID->"d224f699-e5dc-ff4b-9754-af3695dda552"],

Cell["The following options can be given: ", "Notes",
 CellID->13178,ExpressionUUID->"573e0b28-0eee-e047-9783-41f5ac4d5250"],

Cell[BoxData[GridBox[{
   {Cell["      ", "ModInfo",ExpressionUUID->
     "238c5297-10ee-6c40-9a0b-72e46977a63d"], "\"\<BalanceConstant\>\"", 
    "Automatic", Cell["\<\
balance constant of the equation obtained using balancing principle\
\>", "TableText",
     CellChangeTimes->{3.327659391375*^9},ExpressionUUID->
     "24cc9d90-0f6f-4a4f-a325-b3651770e166"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "92638fd5-aec1-c141-9f22-5978d1d6d2df"], "\"\<RationalFunction\>\"", 
    RowBox[{
     FractionBox["1", 
      RowBox[{"1", "+", 
       SuperscriptBox["\[ExponentialE]", "#"]}]], "&"}], Cell[
    "the general exponential rational function used for solving", "TableText",
     CellChangeTimes:>{3.32765943476563*^9, 3.32787906595725*^9, 
      3.34660524546012*^9},ExpressionUUID->
     "7ae71ba4-db4a-6c46-b950-443523fe2148"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "bdd6f656-6dd8-9e40-9065-83aebe7a052d"], "\"\<WaveConstants\>\"", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox[
       StyleBox["\[ScriptW]", "TI"], 
       StyleBox["x", "TI"]], ",", 
      SubscriptBox[
       StyleBox["\[ScriptW]", "TI"], 
       StyleBox["y", "TI"]], ",", "...", ",", 
      SubscriptBox[
       StyleBox["\[ScriptW]", "TI"], 
       StyleBox["t", "TI"]]}], "}"}], Cell[
    "the wave constants used in wave transformation", "TableText",
     CellChangeTimes:>{3.32765943476563*^9, 3.32787906595725*^9, 
      3.34660524546012*^9},ExpressionUUID->
     "4b9b936e-76ab-514b-81ad-e64da5499d24"]}
  }]], "3ColumnTableMod",
 CellChangeTimes->{
  3.32765943476563*^9, 3.32766053485938*^9, 3.32787901726975*^9, 
   3.32787909470725*^9, 3.34660524546012*^9, {3.3751958270231285`*^9, 
   3.3751958270543785`*^9}, 3.3839149012241626`*^9, {3.9839374679351177`*^9, 
   3.9839377769462547`*^9}, {3.98393783031629*^9, 3.983937853169945*^9}, {
   3.9839380224752026`*^9, 3.983938043485796*^9}, {3.983939043040079*^9, 
   3.983939091958441*^9}, {3.9839393456820583`*^9, 3.9839393627207184`*^9}, {
   3.989114240264559*^9, 3.989114241551552*^9}, {3.989114302461073*^9, 
   3.989114532312729*^9}},
 CellID->694357680,ExpressionUUID->"e25d47f1-67fc-4f46-b541-5c03bbe4d207"],

Cell["\"OutputMode\" takes the following values:", "Notes",
 CellChangeTimes->{{3.9839380579785576`*^9, 3.9839380665058746`*^9}},
 CellID->12765947,ExpressionUUID->"c7069855-7d7e-af4c-84e3-776105157d59"],

Cell[BoxData[GridBox[{
   {Cell["      ", "ModInfo",ExpressionUUID->
     "63de964f-4791-3b45-bd7c-08f462597a7d"], "\"\<Solutions\>\"", Cell[
    "solutions in the form of u(x, y, ..., t)", "TableText",
     CellChangeTimes:>{3.34660529783512*^9},ExpressionUUID->
     "5ee78bfe-0092-c440-a689-ad6f585efff1"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "6a0074c1-bcb6-4541-856a-9d25f5b7403d"], "\"\<SolutionSets\>\"", Cell["\<\
sets of dependent and independent variables used to obtain \"Solutions\"\
\>", "TableText",
     CellChangeTimes:>{3.34660529867887*^9},ExpressionUUID->
     "667d836d-08aa-3349-b4bf-7e40f385b368"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "c9407be8-c659-074d-8562-fabb238cfaa9"], "All", Cell[
    "both of the above", "TableText",
     CellChangeTimes:>{3.34660529867887*^9},ExpressionUUID->
     "5fa636ea-fd71-5449-a8c7-832f20c1b5a1"]}
  }]], "2ColumnTableMod",
 CellChangeTimes->{
  3.34660529867887*^9, {3.3751958148512535`*^9, 3.3751958148981285`*^9}, 
   3.3839149133180676`*^9, {3.9839381078190002`*^9, 3.98393822416601*^9}, {
   3.9891145415060253`*^9, 3.989114541818548*^9}},
 CellID->12695,ExpressionUUID->"69874e8f-12a8-5744-8079-7dd302d29fd8"],

Cell["\<\
The balancing constant for wave transformation is calculated automatically \
for the given equation. However, if and when the package fails to calculate \
one, \"BalanceConstant\" be used as described above.\
\>", "Notes",
 CellChangeTimes->{{3.985683283191551*^9, 3.9856832897182217`*^9}, {
  3.9856835518452587`*^9, 3.9856836156870575`*^9}, {3.989114548021017*^9, 
  3.989114548555437*^9}},
 CellID->433568400,ExpressionUUID->"c75b350b-3611-eb49-9f14-bcc3de5592d8"],

Cell[TextData[{
 Cell[BoxData[
  ButtonBox["GERFSolve",
   BaseStyle->"Link",
   ButtonData->"paclet:Taggar/GERF/ref/GERFSolve"]], "InlineFormula",
  ExpressionUUID->"ed4c90b0-6333-b648-a4d2-5217dfaa2a8d"],
 " accepts single nonlinear partial differential equations in integral or \
fractional order."
}], "Notes",
 CellChangeTimes->{{3.985683642949095*^9, 3.9856836725934296`*^9}, {
  3.9891145559699993`*^9, 3.9891145634773865`*^9}},
 CellID->135426554,ExpressionUUID->"439965fe-d163-d84e-8da0-f506bc57035c"],

Cell[TextData[{
 "For fractional order equations, ",
 Cell[BoxData[
  ButtonBox["FractionalD",
   BaseStyle->"Link"]], "InlineFormula",ExpressionUUID->
  "defd6fe6-bd49-0241-b1d5-48970f1758b1"],
 " may be used and the package regards it as the conformal derivative."
}], "Notes",
 CellChangeTimes->{{3.9856836739106216`*^9, 3.985683701624174*^9}},
 CellID->494103842,ExpressionUUID->"9f84c400-e007-754d-94ba-545101480959"],

Cell[TextData[{
 "The wave transformation is considered to be of the form ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Eta]", "TR"], "=", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       SubscriptBox["\[ScriptW]", 
        SubscriptBox[
         StyleBox["x", "TI"], 
         StyleBox["1", "TR"]]], 
       SubscriptBox[
        StyleBox["x", "TI"], "1"]}], "+", 
      RowBox[{
       SubscriptBox["\[ScriptW]", 
        SubscriptBox[
         StyleBox["x", "TI"], 
         StyleBox["2", "TR"]]], 
       SubscriptBox[
        StyleBox["x", "TI"], "2"]}], "+"}], "..."}], "+", 
    RowBox[{
     SubscriptBox["\[ScriptW]", 
      SubscriptBox[
       StyleBox["x", "TI"], 
       StyleBox["n", "TI"]]], 
     SubscriptBox[
      StyleBox["x", "TI"], 
      StyleBox["n", "TI"]]}], "+", 
    RowBox[{
     SubscriptBox["\[ScriptW]", 
      StyleBox["t", "TI"]], 
     StyleBox["t", "TI"]}]}]}]], "InlineFormula",ExpressionUUID->
  "c207c123-0183-df49-a9fa-a245b7c95dff"],
 ". Custom wave transformation constants ",
 Cell[BoxData[
  SubscriptBox["\[ScriptW]", 
   SubscriptBox[
    StyleBox["x", "TI"], 
    StyleBox["i", "TI"]]]], "InlineFormula",ExpressionUUID->
  "9776ab8e-48c1-054e-995a-53337df90e1a"],
 "'s can be provided using \"WaveConstants\" as described above."
}], "Notes",
 CellChangeTimes->{{3.9856837077178764`*^9, 3.9856837585191727`*^9}, {
  3.985693920329359*^9, 3.9856939993945675`*^9}, {3.9891145752866173`*^9, 
  3.9891145764793243`*^9}},
 CellID->43350803,ExpressionUUID->"8dcd2977-d9b0-0043-b16c-16e5c07e2ac6"],

Cell[TextData[{
 "The coefficients in ansatz are taken to be ",
 Cell[BoxData[
  SubscriptBox["\[ScriptCapitalA]", 
   StyleBox["i", "TI"]]], "InlineFormula",ExpressionUUID->
  "bc7ff12b-cea2-4348-80aa-9337c85e5f79"],
 "'s for appropriate ranges of ",
 Cell[BoxData[
  StyleBox["i", "TI"]], "InlineFormula",ExpressionUUID->
  "04660aa4-005a-5545-8cd3-74df8b2eca23"],
 "."
}], "Notes",
 CellChangeTimes->{{3.9856837627440395`*^9, 3.985683805070898*^9}, {
  3.990519094527872*^9, 3.9905190949969406`*^9}},
 CellID->230841850,ExpressionUUID->"6dde27bd-5f80-214a-ab77-6a420a80bc95"],

Cell[TextData[{
 "For systems of equations, the ",
 Cell[BoxData[
  StyleBox["m", "TI"]], "InlineFormula",ExpressionUUID->
  "9d0df5bd-1221-1346-9786-edf86b8fafeb"],
 "th coefficient in the ansatz for ",
 Cell[BoxData[
  StyleBox["k", "TI"]], "InlineFormula",ExpressionUUID->
  "298080e9-b038-1044-950f-4fdc25dba2bd"],
 " is taken as ",
 Cell[BoxData[
  SubsuperscriptBox["\[ScriptCapitalA]", 
   StyleBox["m", "TI"], 
   StyleBox["k", "TI"]]], "InlineFormula",ExpressionUUID->
  "e0965e93-81b5-ce41-b396-4e4c0eb1ce74"],
 "."
}], "Notes",
 CellChangeTimes->{{3.990519085175804*^9, 3.990519180123541*^9}, {
  3.99051921068696*^9, 3.990519252599203*^9}},
 CellID->792293803,ExpressionUUID->"38423bf6-ee36-6b40-9bb1-c5783980c477"],

Cell["\<\
The number of unique equations and the number of unique dependent variables \
must be equal to each other.\
\>", "Notes",
 CellChangeTimes->{{3.990519258936165*^9, 3.990519275302788*^9}},
 CellID->57829300,ExpressionUUID->"60511c97-adfd-f544-a64a-a617bff8cded"]
}, Open  ]],

