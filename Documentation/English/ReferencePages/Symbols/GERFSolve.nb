Cell[BoxData[
 RowBox[{
  RowBox[{"fb", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"FractionalD", "[", 
      RowBox[{
       RowBox[{"u", "[", 
        RowBox[{"x", ",", "t"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"t", ",", "\[Alpha]"}], "}"}]}], "]"}], "+", 
     RowBox[{"\[Beta]", " ", 
      SuperscriptBox[
       RowBox[{"u", "[", 
        RowBox[{"x", ",", "t"}], "]"}], "\[Delta]"], 
      RowBox[{
       SubscriptBox["\[PartialD]", "x"], 
       RowBox[{"u", "[", 
        RowBox[{"x", ",", "t"}], "]"}]}]}], "-", 
     RowBox[{"\[Nu]", " ", 
      RowBox[{
       SubscriptBox["\[PartialD]", 
        RowBox[{"x", ",", "x"}]], 
       RowBox[{"u", "[", 
        RowBox[{"x", ",", "t"}], "]"}]}]}]}], "==", 
    RowBox[{"\[Gamma]", " ", 
     RowBox[{"u", "[", 
      RowBox[{"x", ",", "t"}], "]"}], 
     RowBox[{"(", 
      RowBox[{"1", "-", 
       SuperscriptBox[
        RowBox[{"u", "[", 
         RowBox[{"x", ",", "t"}], "]"}], "2"]}], ")"}]}]}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9904022686349144`*^9, 3.990402278604065*^9}, {
