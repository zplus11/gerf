Cell["Wave constants can be provided using this option:", "ExampleText",
 CellChangeTimes->{{3.989116012164818*^9, 3.9891160225673065`*^9}},
 CellID->599540742,ExpressionUUID->"262c9b29-d80e-8b42-a936-78eefac04f5e"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"GERFSolve", "[", 
  RowBox[{"burgers", ",", 
   RowBox[{"u", "[", 
    RowBox[{"x", ",", "t"}], "]"}], ",", 
   RowBox[{"\"\<WaveConstants\>\"", "->", 
    RowBox[{"{", 
     RowBox[{"1", ",", 
      RowBox[{"-", "c"}]}], "}"}]}]}], "]"}]], "Input",
 CellChangeTimes->{{3.9891159354111233`*^9, 3.989115949542507*^9}},
 CellLabel->"In[2]:=",
