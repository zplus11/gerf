Cell["\<\
Solving the (3\[ThinSpace]+\[ThinSpace]1)-dimensional Hirota\[Dash]Satsuma\
\[Dash]Ito-Like equation given as:\
\>", "ExampleText",
 CellChangeTimes->{{3.989116688767229*^9, 3.9891166934255238`*^9}},
 CellID->550057579,ExpressionUUID->"65e42dd6-84fa-e24d-8bd9-442a9aaa71a5"],

Cell[BoxData[
 RowBox[{
  RowBox[{"eq", "=", 
   RowBox[{
    RowBox[{
     RowBox[{
      SubscriptBox["\[PartialD]", 
       RowBox[{"x", ",", "x", ",", "x", ",", "t"}]], 
      RowBox[{"u", "[", 
       RowBox[{"x", ",", "y", ",", "z", ",", "t"}], "]"}]}], "+", 
     RowBox[{"3", 
      RowBox[{
       SubscriptBox["\[PartialD]", 
        RowBox[{"x", ",", "t"}]], 
       RowBox[{"u", "[", 
        RowBox[{"x", ",", "y", ",", "z", ",", "t"}], "]"}]}], 
      RowBox[{
       SubscriptBox["\[PartialD]", "x"], 
       RowBox[{"u", "[", 
        RowBox[{"x", ",", "y", ",", "z", ",", "t"}], "]"}]}]}], "+", 
     RowBox[{"3", 
      RowBox[{
       SubscriptBox["\[PartialD]", 
        RowBox[{"x", ",", "x"}]], 
       RowBox[{"u", "[", 
        RowBox[{"x", ",", "y", ",", "z", ",", "t"}], "]"}]}], 
      RowBox[{
       SubscriptBox["\[PartialD]", "t"], 
       RowBox[{"u", "[", 
        RowBox[{"x", ",", "y", ",", "z", ",", "t"}], "]"}]}]}], "+", 
     RowBox[{"a", " ", 
      RowBox[{
       SubscriptBox["\[PartialD]", 
        RowBox[{"y", ",", "t"}]], 
       RowBox[{"u", "[", 
        RowBox[{"x", ",", "y", ",", "z", ",", "t"}], "]"}]}]}], "+", 
     RowBox[{"b", " ", 
      RowBox[{
       SubscriptBox["\[PartialD]", 
        RowBox[{"z", ",", "t"}]], 
       RowBox[{"u", "[", 
        RowBox[{"x", ",", "y", ",", "z", ",", "t"}], "]"}]}]}]}], "==", 
    "0"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9891163148919773`*^9, 3.989116372152834*^9}},
 CellLabel->"In[1]:=",
 CellID->31552907,ExpressionUUID->"cb5c7425-a26b-d741-bf51-1cef428bbeb5"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"GERFSolve", "[", "\[IndentingNewLine]", 
   RowBox[{"eq", ",", 
    RowBox[{"u", "[", 
     RowBox[{"x", ",", "y", ",", "z", ",", "t"}], "]"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"\"\<WaveConstants\>\"", "->", 
     RowBox[{"{", 
      RowBox[{"\[Alpha]", ",", "\[Beta]", ",", "\[Gamma]", ",", 
       RowBox[{"-", "p"}]}], "}"}]}], ",", "\[IndentingNewLine]", 
    RowBox[{"\"\<RationalFunction\>\"", "->", 
     RowBox[{"(", 
      RowBox[{
       FractionBox[
        RowBox[{
         RowBox[{"-", "3"}], "-", 
         SuperscriptBox["E", "#"]}], 
        RowBox[{"1", "+", 
         SuperscriptBox["E", "#"]}]], "&"}], ")"}]}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"\"\<OutputMode\>\"", "->", "All"}]}], "\[IndentingNewLine]", 
   "]"}], "[", 
  RowBox[{"[", "7", "]"}], "]"}]], "Input",
 CellChangeTimes->{{3.989116392826706*^9, 3.9891165063968983`*^9}, {
  3.9891166128635807`*^9, 3.989116631482937*^9}, {3.990357368505993*^9, 
  3.9903573997952747`*^9}},
 CellLabel->"In[4]:=",
 CellID->501497221,ExpressionUUID->"c56ac125-c557-4341-8c71-710fefb38c25"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\[Gamma]", "\[Rule]", 
      FractionBox[
       RowBox[{
        RowBox[{"-", 
         SuperscriptBox["\[Alpha]", "3"]}], "-", 
        RowBox[{"a", " ", "\[Beta]"}]}], "b"]}], ",", 
     RowBox[{
      SubscriptBox["\[ScriptCapitalA]", 
       RowBox[{"-", "1"}]], "\[Rule]", 
      RowBox[{
       RowBox[{"-", "3"}], " ", "\[Alpha]"}]}], ",", 
     RowBox[{
      SubscriptBox["\[ScriptCapitalA]", "1"], "\[Rule]", "0"}]}], "}"}], ",", 
   RowBox[{
    RowBox[{"u", "[", 
     RowBox[{"x", ",", "y", ",", "z", ",", "t"}], "]"}], "\[Rule]", 
    RowBox[{
     RowBox[{"-", 
      FractionBox[
       RowBox[{"3", " ", 
        RowBox[{"(", 
         RowBox[{"1", "+", 
          SuperscriptBox["\[ExponentialE]", 
           RowBox[{
            RowBox[{
             RowBox[{"-", "p"}], " ", "t"}], "+", 
            RowBox[{"x", " ", "\[Alpha]"}], "+", 
            RowBox[{"y", " ", "\[Beta]"}], "+", 
            FractionBox[
             RowBox[{"z", " ", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{"-", 
                 SuperscriptBox["\[Alpha]", "3"]}], "-", 
                RowBox[{"a", " ", "\[Beta]"}]}], ")"}]}], "b"]}]]}], ")"}], " ",
         "\[Alpha]"}], 
       RowBox[{
        RowBox[{"-", "3"}], "-", 
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{
          RowBox[{
           RowBox[{"-", "p"}], " ", "t"}], "+", 
          RowBox[{"x", " ", "\[Alpha]"}], "+", 
          RowBox[{"y", " ", "\[Beta]"}], "+", 
          FractionBox[
           RowBox[{"z", " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"-", 
               SuperscriptBox["\[Alpha]", "3"]}], "-", 
              RowBox[{"a", " ", "\[Beta]"}]}], ")"}]}], "b"]}]]}]]}], "+", 
     SubscriptBox["\[ScriptCapitalA]", "0"]}]}]}], "}"}]], "Output",
 CellChangeTimes->{{3.9891164505902386`*^9, 3.989116476905882*^9}, 
   3.98911650752462*^9, {3.9891166164370823`*^9, 3.9891166326060143`*^9}, 
   3.9903573704076385`*^9, 3.9903574009374638`*^9},
 CellLabel->"Out[4]=",
 CellID->606591287,ExpressionUUID->"460397cb-7767-0645-8bc9-60001810c3b1"]
}, Open  ]],

