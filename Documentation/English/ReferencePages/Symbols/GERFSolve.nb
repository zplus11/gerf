Cell["Solve it using GERF method:", "ExampleText",
 CellChangeTimes->{{3.983938299066225*^9, 3.983938304768261*^9}},
 CellID->64291742,ExpressionUUID->"13082efd-9bd1-914a-9707-9a8d64aab254"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"GERFSolve", "[", 
  RowBox[{"burgers", ",", 
   RowBox[{"u", "[", 
    RowBox[{"x", ",", "t"}], "]"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.983938782505268*^9, 3.9839387859446335`*^9}},
 CellLabel->"In[9]:=",
 CellID->7709824,ExpressionUUID->"68b790cc-43f8-ff41-a3a0-6cfb2e136fd2"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"u", "[", 
     RowBox[{"x", ",", "t"}], "]"}], "\[Rule]", 
    RowBox[{
     SubscriptBox["\[ScriptCapitalA]", "0"], "+", 
     FractionBox[
      RowBox[{"2", " ", "\[Nu]", " ", 
       SubscriptBox["\[ScriptW]", "x"]}], 
      RowBox[{"1", "+", 
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{
         RowBox[{"x", " ", 
          SubscriptBox["\[ScriptW]", "x"]}], "+", 
         RowBox[{"t", " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{
             RowBox[{"-", 
              SubscriptBox["\[ScriptCapitalA]", "0"]}], " ", 
             SubscriptBox["\[ScriptW]", "x"]}], "-", 
            RowBox[{"\[Nu]", " ", 
             SubsuperscriptBox["\[ScriptW]", "x", "2"]}]}], ")"}]}]}]]}]]}]}],
    "}"}], "}"}]], "Output",
 CellChangeTimes->{
  3.983938786500757*^9, {3.9839458264237385`*^9, 3.983945869488962*^9}, 
   3.9839459010121784`*^9, 3.983945980529711*^9, {3.9839461567219696`*^9, 
   3.9839461849641495`*^9}, 3.9839462343916855`*^9, 3.983946301348608*^9, {
   3.9839463647962894`*^9, 3.9839463810711136`*^9}, 3.983951301106119*^9, 
   3.989114596941866*^9, 3.9903512878735695`*^9, 3.9903572067882156`*^9, 
   3.990516684763899*^9, 3.990517432012665*^9},
 CellLabel->"Out[9]=",
 CellID->2646850,ExpressionUUID->"9028e7ae-0779-b44d-8c35-1931003752bb"]
}, Open  ]],

Cell["Plot the solution:", "ExampleText",
 CellChangeTimes->{{3.98911477281513*^9, 3.9891147750728664`*^9}},
 CellID->4713124,ExpressionUUID->"13e7c6ca-e5a6-f84b-a393-cb640c1dc4c9"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Plot3D", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     SubscriptBox["\[ScriptCapitalA]", "0"], "+", 
     FractionBox[
      SubscriptBox["\[ScriptCapitalA]", "1"], 
      RowBox[{"1", "+", 
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{
         RowBox[{"x", " ", 
          SubscriptBox["\[ScriptW]", "x"]}], "+", 
         RowBox[{
          FractionBox["1", "2"], " ", "t", " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{
             RowBox[{"-", "2"}], " ", 
             SubscriptBox["\[ScriptCapitalA]", "0"], " ", 
             SubscriptBox["\[ScriptW]", "x"]}], "-", 
            RowBox[{
             SubscriptBox["\[ScriptCapitalA]", "1"], " ", 
             SubscriptBox["\[ScriptW]", "x"]}]}], ")"}]}]}]]}]]}], "/.", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       SubscriptBox["\[ScriptCapitalA]", "0"], "->", "2"}], ",", 
      RowBox[{
       SubscriptBox["\[ScriptCapitalA]", "1"], "->", 
       RowBox[{"-", "1"}]}], ",", 
      RowBox[{
       SubscriptBox["\[ScriptW]", "x"], "->", 
       RowBox[{"-", "1"}]}]}], "}"}]}], ",", "\[IndentingNewLine]", 
   RowBox[{"{", 
    RowBox[{"x", ",", 
     RowBox[{"-", "5"}], ",", "5"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"t", ",", 
     RowBox[{"-", "5"}], ",", "5"}], "}"}]}], "\[IndentingNewLine]", 
  "]"}]], "Input",
