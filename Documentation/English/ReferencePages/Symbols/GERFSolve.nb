Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"u", "[", 
     RowBox[{"x", ",", "t"}], "]"}], "\[Rule]", 
    RowBox[{"c", "-", "\[Nu]", "+", 
     FractionBox[
      RowBox[{"2", " ", "\[Nu]"}], 
      RowBox[{"1", "+", 
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{
         RowBox[{
          RowBox[{"-", "c"}], " ", "t"}], "+", "x"}]]}]]}]}], "}"}], 
  "}"}]], "Output",
