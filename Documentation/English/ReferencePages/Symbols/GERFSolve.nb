Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"GERFSolve", "[", 
  RowBox[{"burgers", ",", 
   RowBox[{"u", "[", 
    RowBox[{"x", ",", "t"}], "]"}], ",", 
   RowBox[{"\"\<RationalFunction\>\"", "->", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"1", "+", 
       RowBox[{"\[ImaginaryI]", " ", 
        RowBox[{"Tan", "[", "#", "]"}]}]}], "&"}], ")"}]}]}], "]"}]], "Input",
